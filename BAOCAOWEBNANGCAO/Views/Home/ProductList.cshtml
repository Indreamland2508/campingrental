@model IEnumerable<BAOCAOWEBNANGCAO.Models.Product>
@{
    ViewData["Title"] = "Hệ sinh thái CampingRental";
    // Sửa thành kiểu int? để khớp với ID của danh mục
    int? currentCatId = ViewBag.CurrentCategory as int?;
}

<style>
    /* BỘ MÀU CHUẨN MINIMALIST */
    :root {
        --forest-dark: #1a4d3a;
        --border-color: #e1e4e8;
    }

    .font-serif {
        font-family: 'Playfair Display', 'Times New Roman', serif;
    }

    .font-monospace {
        font-family: SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    }

    /* 1. BANNER TOÀN CẢNH (EDGE-TO-EDGE) GIỐNG HỆT 2.JPG */
    .full-width-banner {
        width: 100vw;
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
        height: 75vh;
        /* THAY LINK ẢNH DƯỚI ĐÂY BẰNG ẢNH RỪNG THÔNG CỦA BẠN */
        background-image: url('/images/IMG/camtrai.jpg');
        background-size: cover;
        background-position: center center;
        background-repeat: no-repeat;
        margin-bottom: 0; /* Bỏ margin-bottom cũ */
        margin-top: -16px;
    }

    /* 2. === PHẦN GIỚI THIỆU MỚI (CHÂU MUỐN THÊM) === */
    /* === PHẦN GIỚI THIỆU LƯỚI 4 ẢNH (CHUẨN THIẾT KẾ) === */
    .intro-section {
        background-color: #ffffff;
        width: 100vw;
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
        padding-top: 80px;
        padding-bottom: 80px;
        margin-bottom: 50px;
    }

    .intro-container {
        max-width: 1300px;
        margin: 0 auto;
        padding: 0 15px;
        display: flex;
        align-items: center;
        gap: 60px; /* Khoảng cách giữa cụm ảnh và chữ */
    }

    /* BỘ KHUNG 4 ẢNH SO LE */
    .intro-images-wrapper {
        flex: 0 0 45%;
        display: flex;
        gap: 20px;
    }

    .image-column {
        display: flex;
        flex-direction: column;
        gap: 20px;
        width: 50%;
    }

    /* Đẩy cột thứ 2 xuống một chút để tạo độ so le */
    .col-right {
        margin-top: 40px;
    }

    .intro-img {
        width: 100%;
        border-radius: 20px; /* Bo góc lớn giống thiết kế */
        object-fit: cover;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    /* Chỉnh chiều cao từng ảnh để ra hiệu ứng ngẫu nhiên */
    .img-1 {
        height: 240px;
    }

    .img-2 {
        height: 320px;
    }

    .img-3 {
        height: 280px;
    }

    .img-4 {
        height: 300px;
    }

    /* NỘI DUNG CHỮ BÊN PHẢI */
    .intro-text-wrapper {
        flex: 1;
        padding-left: 20px;
    }

    .intro-subtitle-top {
        font-size: 1.15rem;
        font-weight: 700;
        color: #111;
        margin-bottom: 15px;
    }

    .intro-huge-title {
        font-size: 6.5rem; /* Chữ khổng lồ */
        font-weight: 800;
        color: var(--forest-dark);
        line-height: 0.85; /* Ép dòng sát nhau */
        letter-spacing: -2px; /* Khoảng cách chữ hẹp lại */
        margin-bottom: 30px;
    }

    .intro-desc-text {
        font-size: 0.95rem;
        color: #495057;
        line-height: 1.6;
        margin-bottom: 15px;
        max-width: 90%;
    }

    .btn-view-products {
        display: inline-block;
        background-color: #9ca3af; /* Nền xám như ảnh */
        color: #111;
        font-weight: 700;
        font-size: 1.1rem;
        padding: 12px 30px;
        border-radius: 12px;
        text-decoration: none;
        margin-top: 20px;
        transition: 0.3s;
    }

        .btn-view-products:hover {
            background-color: #6b7280;
            color: #fff;
        }

    /* RESPONSIVE */
    @@media (max-width: 992px) {
        .intro-container

    {
        flex-direction: column;
    }

    .intro-images-wrapper {
        width: 100%;
    }

    .intro-huge-title {
        font-size: 4rem;
    }

    .intro-text-wrapper {
        padding-left: 0;
        margin-top: 30px;
    }

    }
    /* TIÊU ĐỀ PHẦN GIỚI THIỆU */
    .about-section-title-wrapper {
        text-align: center;
        margin-bottom: 50px;
    }

    .about-section-main-title {
        font-size: 3rem;
        font-weight: bold;
        color: var(--forest-dark);
        margin: 0;
    }

    /* BỐ CỤC 2 CỘT CHO NỘI DUNG */
    .about-camping-text {
        flex: 1;
        padding-right: 20px;
    }

    .about-camping-image-col {
        flex: 0 0 45%; /* Chiều rộng cột ảnh */
    }

    /* CHI TIẾT TEXT */
    .about-section-subtitle {
        color: var(--forest-dark);
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 10px;
        display: block;
    }

    .about-section-desc {
        font-size: 1rem;
        line-height: 1.6;
        color: #495057;
        margin-bottom: 30px;
    }

    /* DANH SÁCH TÍNH NĂNG */
    .about-features-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .about-features-list li {
            font-size: 1rem;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            color: #495057;
        }

            .about-features-list li::before {
                content: "";
                display: inline-block;
                width: 10px;
                height: 10px;
                background-color: var(--forest-dark);
                border-radius: 50%;
                margin-right: 15px;
                flex-shrink: 0;
            }

    /* ẢNH PHẦN GIỚI THIỆU */
    .about-camping-img {
        width: 100%;
        height: auto;
        object-fit: cover;
        border-radius: 15px;
    }

    /* 3. LAYOUT 2 CỘT (SIDEBAR & LƯỚI SẢN PHẨM) */
    .product-page-container {
        display: flex;
        max-width: 1300px;
        margin: 0 auto;
        padding: 0 15px;
        gap: 40px;
    }

    /* SIDEBAR (MENU BÊN TRÁI) */
    .sidebar {
        flex: 0 0 260px;
        position: sticky;
        top: 20px;
        height: fit-content;
    }

    .category-title-header {
        background-color: var(--forest-dark);
        padding: 20px;
        color: #fff;
        border-radius: 15px 15px 0 0;
    }

    .category-title {
        font-size: 1.2rem;
        font-weight: bold;
        margin: 0;
    }

    .category-list {
        list-style: none;
        padding: 0;
        margin: 0;
        background-color: #f8f9fa;
        border-radius: 0 0 15px 15px;
    }

    .category-item {
        display: block;
        padding: 16px 25px;
        text-decoration: none;
        color: #495057;
        font-size: 1rem;
        border-bottom: 1px solid var(--border-color);
        transition: all 0.2s ease;
    }

        .category-item:last-child {
            border-bottom: none;
        }

        .category-item:hover {
            background-color: #e9ecef;
            color: var(--forest-dark);
        }

        .category-item.active {
            background-color: #e5e7eb;
            color: var(--forest-dark);
            font-weight: bold;
            border-left: 4px solid var(--forest-dark);
            padding-left: 21px;
        }

    /* MAIN CONTENT AREA */
    .main-content {
        flex: 1;
    }

    /* TOOLBAR (BỘ LỌC) */
    .toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: #fff;
        padding: 15px 0;
        border-bottom: 1px solid var(--border-color);
        margin-bottom: 30px;
    }

    .toolbar-left, .toolbar-right {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .toolbar-label {
        font-size: 0.9rem;
        color: #6c757d;
        font-weight: 600;
    }

    .price-input {
        padding: 8px 12px;
        border: 1px solid #ced4da;
        border-radius: 8px;
        width: 100px;
        font-size: 0.9rem;
        outline: none;
    }

    .btn-search-icon {
        background: none;
        border: 1px solid #ced4da;
        padding: 8px 12px;
        border-radius: 8px;
        color: #6c757d;
        cursor: pointer;
    }

    .sort-btn {
        background-color: #f8f9fa;
        border: 1px solid var(--border-color);
        padding: 8px 15px;
        border-radius: 8px;
        color: #495057;
        font-size: 0.9rem;
        cursor: pointer;
    }

        .sort-btn.active {
            background-color: #e5e7eb;
            font-weight: bold;
            color: #212529;
        }

    /* CARD SẢN PHẨM LUXURY (CỦA BẠN) */
    .product-luxury-card {
        border: none !important;
        background: transparent;
        transition: all 0.4s ease;
        margin-bottom: 40px;
        text-decoration: none !important;
        display: block;
    }

    .img-luxury-frame {
        background-color: #f9fafb;
        border: 1px solid #f3f4f6;
        border-radius: 25px;
        aspect-ratio: 1 / 1;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        transition: 0.4s ease;
    }

        .img-luxury-frame img {
            width: 90%;
            height: 90%;
            object-fit: contain;
            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

    .product-luxury-card:hover .img-luxury-frame {
        background-color: #ffffff;
        border-color: var(--forest-dark);
        box-shadow: 0 15px 30px rgba(26, 77, 58, 0.1);
    }

    .product-luxury-card:hover img {
        transform: scale(1.05);
    }

    .product-info-minimal {
        padding-top: 15px;
        text-align: center;
    }

    .luxury-cat-name {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #6c757d;
        margin-bottom: 5px;
        display: block;
    }

    .luxury-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: #212529;
        margin-bottom: 8px;
        display: block;
        line-height: 1.4;
        height: 3rem;
        overflow: hidden;
    }

    .luxury-price {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--forest-dark);
    }

    .wishlist-btn {
        position: absolute;
        top: 15px;
        right: 15px;
        color: #9ca3af;
        font-size: 1.2rem;
        z-index: 5;
        transition: 0.3s;
        background: white;
        width: 35px;
        height: 35px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

        .wishlist-btn:hover {
            color: #dc3545;
            transform: scale(1.1);
        }

    /* HIỆU ỨNG HIỆN DẦN */
    .product-reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.5s ease-out;
    }

        .product-reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

    /* RESPONSIVE */
    @@media (max-width: 992px) {
        .product-page-container

    {
        flex-direction: column;
    }

    .sidebar {
        flex: none;
        width: 100%;
        position: relative;
        top: 0;
    }

    .category-list {
        display: flex;
        overflow-x: auto;
        white-space: nowrap;
        border-radius: 0 0 15px 15px;
    }

    .category-item {
        border-bottom: none;
        border-right: 1px solid var(--border-color);
    }

    .full-width-banner {
        height: 50vh;
    }

    .about-camping-content {
        flex-direction: column;
    }

    .about-camping-image-col {
        width: 100%;
    }

    .about-section-main-title {
        font-size: 2.2rem;
    }

    }
</style>

<div class="full-width-banner"></div>

<section class="intro-section">
    <div class="intro-container">

        <div class="intro-images-wrapper">
            <div class="image-column col-left">
                <img src="/images/IMG/leu1.jpg" class="intro-img img-1" alt="Camping 1">
                <img src="/images/IMG/leu2.jpg" class="intro-img img-2" alt="Camping 2">
            </div>
            <div class="image-column col-right">
                <img src="/images/IMG/leu3.jpg" class="intro-img img-3" alt="Camping 3">
                <img src="/images/IMG/leu4.jpg" class="intro-img img-4" alt="Camping 4">
            </div>
        </div>

        <div class="intro-text-wrapper">
            <div class="intro-subtitle-top">Dịch vụ cho thuê lều trại và phụ kiện dã ngoại chuyên nghiệp.</div>

            <h1 class="intro-huge-title font-serif">Camping<br>Rental</h1>

            <p class="intro-desc-text">Khám phá vẻ đẹp nguyên sơ của thiên nhiên cùng những trang bị cắm trại chất lượng nhất. Từ những buổi chiều hoàng hôn trên núi đến đêm ngàn sao rực rỡ.</p>
            <p class="intro-desc-text">Camping Rental sẽ đồng hành cùng bạn tạo nên những kỷ niệm khó quên, mang sự tiện nghi đến bất cứ nơi đâu bạn dừng chân.</p>

            <a href="javascript:void(0)" onclick="document.getElementById('product-section').scrollIntoView({behavior: 'smooth'})" class="btn-view-products">Xem sản phẩm ↓</a>
        </div>

    </div>
</section>

<div class="product-page-container pb-5" id="product-section">

    <aside class="sidebar">
        <div class="category-title-header">
            <h3 class="category-title font-serif">Danh mục</h3>
        </div>
        <ul class="category-list">
            <li>
                <a asp-action="ProductList" asp-route-categoryId="" data-category-id="" class="category-item category-ajax-link @(currentCatId == null ? "active" : "")">
                    Tất cả
                </a>
            </li>
            @if (ViewBag.Categories != null)
            {
                foreach (var cat in ViewBag.Categories)
                {
                    <li>
                        <a asp-action="ProductList" asp-route-categoryId="@cat.Id" data-category-id="@cat.Id" class="category-item category-ajax-link @(currentCatId == cat.Id ? "active" : "")">
                            @cat.Name
                        </a>
                    </li>
                }
            }
        </ul>
    </aside>

    <main class="main-content">

        <div id="product-update-zone" style="transition: opacity 0.3s ease;">

            <form id="filterForm" method="get" asp-action="ProductList" asp-controller="Home" class="mb-4 pb-3 border-bottom">

                <input type="hidden" name="categoryId" value="@ViewBag.CurrentCategory" />
                <input type="hidden" name="sortOrder" id="sortOrderInput" value="@ViewBag.SortOrder" />
                <input type="hidden" name="page" id="pageInput" value="@ViewBag.CurrentPage" />

                <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">

                    <div class="d-flex align-items-center">
                        <span class="me-2 fw-bold text-muted small text-uppercase">Giá</span>
                        <input type="number" name="minPrice" class="form-control form-control-sm text-center shadow-sm border-light me-2" style="width: 90px; border-radius: 10px;" value="@ViewBag.MinPrice" placeholder="Min" />
                        <span class="me-2 text-muted">-</span>
                        <input type="number" name="maxPrice" class="form-control form-control-sm text-center shadow-sm border-light me-2" style="width: 90px; border-radius: 10px;" value="@ViewBag.MaxPrice" placeholder="Max" />
                        <button type="submit" class="btn btn-sm btn-light border shadow-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                            <i class="bi bi-search text-success"></i>
                        </button>
                    </div>

                    <div class="d-flex align-items-center gap-2 gap-md-4">

                        <div class="btn-group shadow-sm" role="group">
                            <button type="button" class="btn btn-sm @(ViewBag.SortOrder == "desc" ? "btn-secondary text-white" : "btn-light text-muted") btn-sort" data-sort="desc" style="border-radius: 10px 0 0 10px;">
                                Cao đến thấp
                            </button>
                            <button type="button" class="btn btn-sm @(ViewBag.SortOrder == "asc" ? "btn-secondary text-white" : "btn-light text-muted") btn-sort" data-sort="asc" style="border-radius: 0 10px 10px 0;">
                                Thấp đến cao
                            </button>
                        </div>

                        <div class="d-flex align-items-center bg-light border rounded-pill px-2 py-1 shadow-sm">
                            <button type="button" class="btn btn-sm btn-link text-decoration-none btn-page p-0 px-2 @(ViewBag.CurrentPage <= 1 ? "text-muted disabled" : "text-dark fw-bold")" data-page="@(ViewBag.CurrentPage - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </button>

                            <span class="mx-2 fw-bold small" style="letter-spacing: 1px;">
                                @ViewBag.CurrentPage / @ViewBag.TotalPages
                            </span>

                            <button type="button" class="btn btn-sm btn-link text-decoration-none btn-page p-0 px-2 @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "text-muted disabled" : "text-dark fw-bold")" data-page="@(ViewBag.CurrentPage + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>

                    </div>
                </div>
            </form>

            <div class="row g-4" id="product-list-container">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <div class="col-lg-4 col-md-6 product-reveal">
                            <a asp-action="Details" asp-route-id="@item.Id" class="product-luxury-card">
                                <div class="img-luxury-frame">
                                    <div class="wishlist-btn"><i class="bi bi-heart"></i></div>
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/no-image.png" : item.ImageUrl)"
                                         alt="@item.Name">
                                </div>
                                <div class="product-info-minimal">
                                    <span class="luxury-cat-name">@(item.Category?.Name ?? "Dã ngoại")</span>
                                    <span class="luxury-title">@item.Name</span>
                                    <div class="luxury-price">@item.PricePerDay.ToString("#,##0") đ <span class="text-muted fw-light" style="font-size: 0.8rem;">/ ngày</span></div>
                                </div>
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <h4 class="text-muted font-serif fst-italic">Không tìm thấy sản phẩm nào phù hợp.</h4>
                    </div>
                }
            </div>

        </div>
    </main>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            // ==========================================
            // HÀM 1: KHỞI TẠO HIỆU ỨNG HIỆN DẦN SẢN PHẨM
            // ==========================================
            function initObserver() {
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach((entry, index) => {
                        if (entry.isIntersecting) {
                            setTimeout(() => {
                                entry.target.classList.add('active');
                            }, index * 50); // Mỗi sản phẩm hiện cách nhau 50ms tạo hiệu ứng lượn sóng
                            observer.unobserve(entry.target);
                        }
                    });
                }, { threshold: 0.1 });

                document.querySelectorAll('.product-reveal').forEach(el => observer.observe(el));
            }

            // Chạy hiệu ứng lần đầu khi trang load
            initObserver();

            // ==========================================
            // HÀM 2: GỌI AJAX KHI BẤM CHUYỂN TRANG / LỌC
            // ==========================================
            function loadProducts() {
                const form = $('#filterForm');
                const url = form.attr('action') + '?' + form.serialize();

                // Làm mờ để báo hiệu đang tải
                $('#product-update-zone').css('opacity', '0.4');

                $.ajax({
                    url: url,
                    type: 'GET',
                    success: function (response) {
                        // Trích xuất "ruột" mới từ kết quả trả về
                        const newContent = $(response).find('#product-update-zone').html();

                        // Đắp ruột mới vào và trả lại độ sáng
                        $('#product-update-zone').html(newContent);
                        $('#product-update-zone').css('opacity', '1');

                        // Đổi URL trên thanh trình duyệt
                        window.history.pushState({path: url}, '', url);

                        // Trượt nhẹ lên đầu thanh công cụ
                        const y = $('#product-section').offset().top - 80;
                        window.scrollTo({ top: y, behavior: 'smooth' });

                        // QUAN TRỌNG: Khởi tạo lại hiệu ứng hiện dần cho các sản phẩm mới
                        initObserver();
                    },
                    error: function () {
                        alert("Có lỗi xảy ra khi tải dữ liệu. Vui lòng thử lại!");
                        $('#product-update-zone').css('opacity', '1');
                    }
                });
            }

            // ==========================================
            // GẮN SỰ KIỆN CHO CÁC NÚT (AJAX)
            // ==========================================

            // 1. Nút sắp xếp (Cao đến thấp...)
            $(document).on('click', '.btn-sort', function (e) {
                e.preventDefault();
                $('#sortOrderInput').val($(this).data('sort'));
                $('#pageInput').val(1);
                loadProducts();
            });

            // 2. Nút phân trang ( < > )
            $(document).on('click', '.btn-page:not(.disabled)', function (e) {
                e.preventDefault();
                $('#pageInput').val($(this).data('page'));
                loadProducts();
            });

            // 3. Form lọc khoảng giá (bấm nút kính lúp)
            $(document).on('submit', '#filterForm', function (e) {
                e.preventDefault();
                $('#pageInput').val(1);
                loadProducts();
            });
            // 4
            $(document).on('click', '.category-ajax-link', function (e) {
                e.preventDefault(); // Ngăn trình duyệt tải lại trang (chống giật lên đầu)

                // Tự động đổi hiệu ứng in đậm sang mục vừa bấm
                $('.category-ajax-link').removeClass('active');
                $(this).addClass('active');

                // Lấy mã danh mục (Id) nhét vào ô input ẩn của Form
                const catId = $(this).data('category-id');
                $('input[name="categoryId"]').val(catId);

                // Khi đổi danh mục thì phải quay về trang số 1
                $('#pageInput').val(1);

                // Kích hoạt thần chú AJAX
                loadProducts();
            });
        });
    </script>
}