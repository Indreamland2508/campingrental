@{
    ViewData["Title"] = "Cẩm nang dã ngoại";
}

<style>
    :root {
        --forest-dark: #1a4d3a;
        --border-color: #e1e4e8;
    }

    .font-serif {
        font-family: 'Playfair Display', 'Times New Roman', serif;
    }

    /* TIÊU ĐỀ TRANG */
    .blog-header {
        padding: 60px 0 40px 0;
        text-align: center;
        border-bottom: 1px solid var(--border-color);
        margin-bottom: 50px;
    }

    .blog-main-title {
        font-size: 3.5rem;
        font-weight: 800;
        color: var(--forest-dark);
        margin-bottom: 15px;
    }

    /* BÀI VIẾT NỔI BẬT (FEATURED POST) */
    .featured-post {
        margin-bottom: 80px;
    }

    .featured-img-wrapper {
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 15px 35px rgba(0,0,0,0.06);
        aspect-ratio: 16 / 7;
        position: relative;
    }

    .featured-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s ease;
    }

    .featured-post:hover .featured-img {
        transform: scale(1.03);
    }

    .post-category {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--forest-dark);
        margin-bottom: 10px;
        display: block;
    }

    .featured-title {
        font-size: 2.5rem;
        font-weight: 800;
        color: #111;
        line-height: 1.2;
        margin-bottom: 15px;
        text-decoration: none;
    }

        .featured-title:hover {
            color: var(--forest-dark);
        }

    .post-excerpt {
        font-size: 1.1rem;
        color: #555;
        line-height: 1.6;
    }

    /* LƯỚI BÀI VIẾT THƯỜNG (GRID POSTS) */
    .post-card {
        margin-bottom: 40px;
        text-decoration: none !important;
        display: block;
    }

    .post-img-wrapper {
        border-radius: 15px;
        overflow: hidden;
        aspect-ratio: 4 / 3;
        margin-bottom: 20px;
        background-color: #f8f9fa;
    }

    .post-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }

    .post-card:hover .post-img {
        transform: scale(1.05);
    }

    .post-card-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: #212529;
        line-height: 1.3;
        margin-bottom: 10px;
        font-family: 'Playfair Display', serif;
        transition: 0.3s;
    }

    .post-card:hover .post-card-title {
        color: var(--forest-dark);
    }

    .post-meta {
        font-size: 0.85rem;
        color: #888;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    /* HIỆU ỨNG HIỆN DẦN */
    .fade-up {
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.6s ease-out;
    }

        .fade-up.visible {
            opacity: 1;
            transform: translateY(0);
        }
</style>

<div class="blog-header fade-up">
    <div class="container">
        <h1 class="blog-main-title font-serif">Cẩm Nang Dã Ngoại</h1>
        <p class="text-muted fs-5">Kinh nghiệm, địa điểm và những câu chuyện truyền cảm hứng từ Camping Rental.</p>
    </div>
</div>

<div class="container pb-5">

    <article class="featured-post fade-up" style="transition-delay: 0.1s;">
        <div class="row align-items-center">
            <div class="col-lg-8 mb-4 mb-lg-0">
                <a href="#" class="featured-img-wrapper d-block">
                    <img src="/images/IMG/camtrai.jpg" alt="Featured Post" class="featured-img">
                </a>
            </div>
            <div class="col-lg-4 ps-lg-4">
                <span class="post-category">Kinh nghiệm người mới</span>
                <a href="#" class="text-decoration-none"><h2 class="featured-title font-serif">Lần đầu đi cắm trại: Cần chuẩn bị những gì để không bị "fail"?</h2></a>
                <p class="post-excerpt">
                    Đi cắm trại không chỉ là xách balo lên và đi. Để có một đêm ngàn sao trọn vẹn, không bị muỗi đốt hay lạnh cóng, đây là danh sách những vật dụng "sống còn" mà bạn tuyệt đối không được quên.
                </p>
                <div class="post-meta mt-4">
                    <span><i class="bi bi-calendar3"></i> 20/03/2026</span>
                    <span><i class="bi bi-pencil-fill"></i> Hoàng Châu</span>
                </div>
            </div>
        </div>
    </article>

    <hr class="mb-5 border-secondary opacity-25 fade-up">

    <h3 class="font-serif fw-bold mb-4 fade-up">Bài viết mới nhất</h3>

    <div class="row g-4">

        <div class="col-lg-4 col-md-6 fade-up" style="transition-delay: 0.1s;">
            <a href="#" class="post-card">
                <div class="post-img-wrapper">
                    <img src="/images/CamNang/anh1.jpg" alt="Post 1" class="post-img">
                </div>
                <span class="post-category">Review Địa điểm</span>
                <h3 class="post-card-title">Top 5 bãi cắm trại sát xịt Hà Nội, sáng đi chiều về cực chill</h3>
                <p class="text-muted" style="font-size: 0.95rem;">Đồng Mô, Sơn Tinh Camp hay Hàm Lợn? Cùng Camping Rental khám phá những tọa độ check-in cực hot dịp cuối tuần này.</p>
                <div class="post-meta mt-3">
                    <span>20/03/2026</span> • <span>Xuân Trường</span>
                </div>
            </a>
        </div>

        <div class="col-lg-4 col-md-6 fade-up" style="transition-delay: 0.2s;">
            <a href="#" class="post-card">
                <div class="post-img-wrapper">
                    <img src="/images/products/COMBO LỀU 2 NGƯỜI 2 LỚP NATUREHIKE CAO CẤP.jpg" alt="Post 2" class="post-img">
                </div>
                <span class="post-category">Mẹo vặt</span>
                <h3 class="post-card-title">Tuyệt chiêu dựng lều Naturehike chỉ trong 5 phút</h3>
                <p class="text-muted" style="font-size: 0.95rem;">Không cần dùng sức, chỉ cần dùng mẹo. Hướng dẫn chi tiết cách dựng lều tự bung và lều khung chéo chuẩn xác nhất.</p>
                <div class="post-meta mt-3">
                    <span>18/03/2026</span> • <span>Hoàng Châu</span>
                </div>
            </a>
        </div>

        <div class="col-lg-4 col-md-6 fade-up" style="transition-delay: 0.3s;">
            <a href="#" class="post-card">
                <div class="post-img-wrapper">
                    <img src="/images/CamNang/bbq.jpg" alt="Post 3" class="post-img">
                </div>
                <span class="post-category">Ẩm thực dã ngoại</span>
                <h3 class="post-card-title">Thực đơn BBQ cắm trại: Ăn ngon mà không cần chuẩn bị cầu kỳ</h3>
                <p class="text-muted" style="font-size: 0.95rem;">Gợi ý set đồ nướng BBQ cực "cuốn" dành cho nhóm bạn, tiết kiệm chi phí mà vẫn đảm bảo lên hình sống ảo cực xịn.</p>
                <div class="post-meta mt-3">
                    <span>15/03/2026</span> • <span>Xuân Trường</span>
                </div>
            </a>
        </div>

    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                        observer.unobserve(entry.target); // Chạy 1 lần duy nhất
                    }
                });
            }, { threshold: 0.1 });

            document.querySelectorAll('.fade-up').forEach((el) => {
                observer.observe(el);
            });
        });
    </script>
}