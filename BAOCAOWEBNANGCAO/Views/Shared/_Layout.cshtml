@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Camping Rental</title>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">

    <link rel="icon" type="image/x-icon" href="~/icon.jpg" />

    <style>
        /* MÀU CHỦ ĐẠO */
        :root {
            --forest-dark: #1a3a28;
        }

        /* 1. THANH MENU (NAVBAR) - PHONG CÁCH TỐI GIẢN */
        .navbar-camping {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid rgba(26, 58, 40, 0.08); /* Viền mỏng thanh lịch */
            transition: all 0.3s;
            padding: 15px 0; /* Tăng khoảng thở */
        }

        .navbar-brand-elegant {
            font-family: 'Playfair Display', 'Times New Roman', serif;
            font-weight: 700;
            color: var(--forest-dark) !important;
            letter-spacing: 1px;
            font-size: 1.8rem;
            text-transform: uppercase;
        }

        .nav-link-custom {
            color: #4b5563 !important; /* Chữ màu xám đậm sang trọng */
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin: 0 15px;
            position: relative;
            transition: color 0.3s;
        }

            .nav-link-custom:hover, .nav-link-custom.active {
                color: var(--forest-dark) !important;
            }

            /* Hiệu ứng gạch chân tinh tế từ giữa mọc ra */
            .nav-link-custom::after {
                content: '';
                position: absolute;
                width: 0;
                height: 1px;
                bottom: -5px;
                left: 50%;
                transform: translateX(-50%);
                background-color: var(--forest-dark);
                transition: 0.3s ease-in-out;
            }

            .nav-link-custom:hover::after {
                width: 100%;
            }

        /* 2. CỤM ICON & AUTH */
        .auth-group {
            display: flex;
            align-items: center;
            gap: 22px;
            min-width: 160px;
            justify-content: flex-end;
        }

        .header-icon {
            color: var(--forest-dark);
            font-size: 1.3rem;
            transition: 0.3s;
            text-decoration: none;
            background: none;
            border: none;
            padding: 0;
        }

            .header-icon:hover {
                color: #198754;
                transform: scale(1.1);
            }

        /* 3. KHUNG TÌM KIẾM SANG TRỌNG (SEARCH OVERLAY) */
        .search-overlay {
            height: 100%;
            width: 100%;
            display: none;
            position: fixed;
            z-index: 2500;
            top: 0;
            left: 0;
            background-color: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(15px);
            transition: 0.5s;
        }

        .search-overlay-content {
            position: relative;
            top: 25%;
            width: 70%;
            margin: auto;
            text-align: center;
        }

        .search-input-luxury {
            width: 100%;
            font-size: 3rem;
            border: none;
            border-bottom: 1px solid var(--forest-dark);
            background: transparent;
            outline: none;
            padding: 10px;
            font-family: 'Playfair Display', serif;
            color: var(--forest-dark);
        }

            .search-input-luxury::placeholder {
                color: #cbd5e1;
                font-family: sans-serif;
                font-weight: 300;
            }

        .close-search {
            position: absolute;
            top: 40px;
            right: 60px;
            font-size: 2.5rem;
            background: none;
            border: none;
            cursor: pointer;
            color: var(--forest-dark);
            transition: 0.3s;
        }

            .close-search:hover {
                color: #dc3545;
                transform: rotate(90deg);
            }

        #searchSuggestions .suggestion-item {
            transition: 0.3s;
            border-radius: 15px;
            padding: 10px;
        }

            #searchSuggestions .suggestion-item:hover {
                background: rgba(26, 58, 40, 0.05);
                transform: translateY(-5px);
            }

        /* 4. FOOTER */
        .footer-camping {
            background-color: var(--forest-dark);
            color: #e8f5e9;
        }

            .footer-camping h5, .footer-camping h6 {
                color: white;
                font-family: 'Playfair Display', serif;
                letter-spacing: 1px;
            }

            .footer-camping .text-muted {
                color: rgba(255, 255, 255, 0.6) !important;
            }

        /* --- CỤM NÚT LIVE CHAT THẢ NỔI --- */
        .floating-chat {
            position: fixed;
            bottom: 30px;
            right: 30px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            z-index: 9999;
        }

        .chat-btn {
            width: 55px;
            height: 55px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            position: relative;
            transition: transform 0.3s;
        }

            .chat-btn:hover {
                transform: scale(1.1);
            }

            .chat-btn .tooltip-text {
                position: absolute;
                right: 70px;
                background-color: #333;
                color: #fff;
                padding: 6px 12px;
                border-radius: 8px;
                font-size: 0.85rem;
                font-weight: bold;
                white-space: nowrap;
                opacity: 0;
                pointer-events: none;
                transition: opacity 0.3s, transform 0.3s;
                transform: translateX(10px);
            }

            .chat-btn:hover .tooltip-text {
                opacity: 1;
                transform: translateX(0);
            }

        .zalo-btn {
            background-color: #0068ff;
            animation: pulse-zalo 2s infinite;
        }

            .zalo-btn img {
                width: 35px;
                height: 35px;
                object-fit: contain;
            }

        @@keyframes pulse-zalo {
            0% {
                box-shadow: 0 0 0 0 rgba(0, 104, 255, 0.7);
            }

            70% {
                box-shadow: 0 0 0 15px rgba(0, 104, 255, 0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(0, 104, 255, 0);
            }
        }

        .phone-btn {
            background-color: var(--forest-dark);
            color: white;
            font-size: 1.5rem;
            animation: pulse-phone 2s infinite 1s;
        }

        @@keyframes pulse-phone {
            0% {
                box-shadow: 0 0 0 0 rgba(26, 58, 40, 0.7);
            }

            70% {
                box-shadow: 0 0 0 15px rgba(26, 58, 40, 0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(26, 58, 40, 0);
            }
        }
    </style>
</head>
<body>
    <div id="searchOverlay" class="search-overlay">
        <button type="button" class="close-search" onclick="closeSearch()">
            <i class="bi bi-x-lg"></i>
        </button>
        <div class="search-overlay-content">
            <form asp-controller="Home" asp-action="ProductList" method="get">
                <input type="text" name="searchString" id="searchInputLuxury"
                       placeholder="Bạn cần tìm trang bị gì?..." class="search-input-luxury" autocomplete="off">
                <p class="text-muted mt-4 small fw-bold text-uppercase" style="letter-spacing: 2px;">
                    Nhấn Enter để khám phá thiên nhiên
                </p>
            </form>

            <div id="searchSuggestions" class="mt-5 row g-4 justify-content-center">
            </div>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg navbar-camping sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand navbar-brand-elegant d-flex align-items-center" asp-controller="Home" asp-action="Index">
                <i class="bi bi-tent me-2 fs-2"></i>CAMPING RENTAL
            </a>

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link nav-link-custom" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link nav-link-custom" asp-controller="Home" asp-action="ProductList">Sản phẩm</a></li>
                    <li class="nav-item"><a class="nav-link nav-link-custom" asp-controller="Home" asp-action="DiaDiem">Địa điểm</a></li>
                    <li class="nav-item"><a class="nav-link nav-link-custom" asp-controller="Home" asp-action="CamNang">Cẩm nang</a></li>
                    <li class="nav-item"><a class="nav-link nav-link-custom" asp-controller="Home" asp-action="FAQ">Hỏi đáp</a></li>
                    <li class="nav-item"><a class="nav-link nav-link-custom" asp-controller="Home" asp-action="OrderTracking">Tra cứu đơn hàng</a></li>
                </ul>

                <div class="auth-group">
                    <button class="header-icon" onclick="openSearch()" title="Tìm kiếm">
                        <i class="bi bi-search"></i>
                    </button>

                    @{
                        var count = HttpContextAccessor.HttpContext.Session.GetInt32("CartCount") ?? 0;
                    }
                    <a class="header-icon position-relative" asp-controller="Cart" asp-action="Index" title="Giỏ hàng">
                        <i class="bi bi-handbag"></i>
                        @if (count > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">@count</span>
                        }
                    </a>

                    @if (SignInManager.IsSignedIn(User))
                    {
                        <div class="dropdown">
                            <a class="header-icon dropdown-toggle d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person"></i>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-2" style="border-radius: 15px;">
                                <li><a class="dropdown-item rounded-3" asp-controller="Accounts" asp-action="MyProfile"><i class="bi bi-person-vcard me-2"></i>Hồ sơ</a></li>
                                @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                                {
                                    <li><a class="dropdown-item rounded-3 fw-bold" style="color: #1a3a28;" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Quản trị</a></li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home")" method="post">
                                        <button type="submit" class="dropdown-item text-danger rounded-3"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Login" class="header-icon" title="Đăng nhập">
                            <i class="bi bi-person"></i>
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main role="main">@RenderBody()</main>

    <footer class="footer-camping pt-5 pb-3 border-top mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <h5 class="fw-bold mb-3 d-flex align-items-center"><i class="bi bi-tent me-2 fs-3"></i> CAMPING RENTAL</h5>
                    <p class="text-muted small lh-lg">Chúng tôi đồng hành cùng Châu và Trường trong dự án cung cấp thiết bị cắm trại cao cấp. Khám phá thiên nhiên theo cách chuyên nghiệp nhất.</p>
                    <div class="d-flex gap-2 mt-3">
                        <a href="http://facebook.com/truongg214" class="btn btn-outline-light btn-sm rounded-circle"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="btn btn-outline-light btn-sm rounded-circle"><i class="bi bi-instagram"></i></a>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6 text-center">
                    <h6 class="fw-bold mb-4 text-uppercase">Khám phá</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-3"><a asp-action="ProductList" class="text-decoration-none text-muted hover-white">Danh sách Lều</a></li>
                        <li class="mb-3"><a asp-action="DiaDiem" class="text-decoration-none text-muted hover-white">Địa điểm dã ngoại</a></li>
                        <li class="mb-3"><a asp-action="CamNang" class="text-decoration-none text-muted hover-white">Cẩm nang & Kinh nghiệm</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-6">
                    <h6 class="fw-bold mb-4 text-uppercase">Liên hệ ngay</h6>
                    <ul class="list-unstyled small text-muted lh-lg">
                        <li class="mb-2"><i class="bi bi-geo-alt text-white me-2"></i> Đại học Điện Lực (EPU), Hà Nội</li>
                        <li class="mb-2"><i class="bi bi-envelope text-white me-2"></i> contact@campingrental.vn</li>
                        <li class="mb-2"><i class="bi bi-telephone text-white me-2"></i> 0982.412.005</li>
                    </ul>
                </div>
            </div>
            <hr class="my-4" style="border-color: rgba(255,255,255,0.1);">
            <div class="row align-items-center">
                <div class="col-md-12 text-center">
                    <p class="text-muted small mb-0">&copy; 2026 Camping Rental. Proudly designed by <span class="text-white font-serif fst-italic fs-6">Hoàng Châu & Xuân Trường</span>.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function openSearch() {
            document.getElementById("searchOverlay").style.display = "block";
            setTimeout(() => { document.getElementById("searchInputLuxury").focus(); }, 100);
        }

        function closeSearch() {
            document.getElementById("searchOverlay").style.display = "none";
            $("#searchSuggestions").empty();
        }

        document.addEventListener('keydown', function(event) {
            if (event.key === "Escape") closeSearch();
        });

        $(document).ready(function () {
            $("#searchInputLuxury").on("input", function () {
                var keyword = $(this).val();
                if (keyword.length > 1) {
                    $.ajax({
                        url: '/Home/GetSuggestions',
                        data: { term: keyword },
                        success: function (data) {
                            var html = "";
                            if(data.length > 0) {
                                data.forEach(item => {
                                    html += `
                                        <div class="col-6 col-md-2 suggestion-item">
                                            <a href="/Home/Details/${item.id}" class="text-decoration-none text-dark">
                                                <img src="${item.image}" class="img-fluid rounded-4 mb-3 shadow-sm" style="height: 120px; width: 100%; object-fit: cover;">
                                                <p class="small fw-bold mb-0 text-truncate font-serif">${item.name}</p>
                                            </a>
                                        </div>`;
                                });
                            }
                            $("#searchSuggestions").html(html);
                        }
                    });
                } else {
                    $("#searchSuggestions").empty();
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <div class="floating-chat">
        <a href="tel:0982412005" class="chat-btn phone-btn shadow-lg">
            <i class="bi bi-telephone"></i>
            <span class="tooltip-text">Gọi Hotline ngay</span>
        </a>

        <a href="https://zalo.me/0982412005" target="_blank" class="chat-btn zalo-btn shadow-lg">
            <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/9/91/Icon_of_Zalo.svg/1200px-Icon_of_Zalo.svg.png" alt="Zalo">
            <span class="tooltip-text">Chat với Châu & Trường</span>
        </a>
    </div>
</body>
</html>