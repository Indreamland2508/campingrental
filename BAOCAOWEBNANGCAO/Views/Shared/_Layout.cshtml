@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Camping Rental</title>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">

    <link rel="icon" type="image/x-icon" href="~/icon.jpg" />

    <link rel="stylesheet" href="~/css/Shared.Layout.css" />
</head>
<body>
    <div id="searchOverlay" class="search-overlay">
        <button type="button" class="close-search" onclick="closeSearch()">
            <i class="bi bi-x-lg"></i>
        </button>
        <div class="search-overlay-content">
            <form asp-controller="Home" asp-action="ProductList" method="get">
                <input type="text" name="searchString" id="searchInputLuxury"
                       placeholder="Bạn cần tìm trang bị gì?..." class="search-input-luxury" autocomplete="off">
                <p class="text-muted mt-4 small fw-bold text-uppercase" style="letter-spacing: 2px;">
                    Nhấn Enter để khám phá thiên nhiên
                </p>
            </form>

            <div id="searchSuggestions" class="mt-5 row g-4 justify-content-center">
            </div>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg navbar-camping sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand navbar-brand-elegant d-flex align-items-center" asp-controller="Home" asp-action="Index">
                <i class="bi bi-tent me-2 fs-2"></i>CAMPING RENTAL
            </a>

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link nav-link-custom" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link nav-link-custom" asp-controller="Home" asp-action="ProductList">Sản phẩm</a></li>
                    <li class="nav-item"><a class="nav-link nav-link-custom" asp-controller="Home" asp-action="DiaDiem">Địa điểm</a></li>
                    <li class="nav-item"><a class="nav-link nav-link-custom" asp-controller="Home" asp-action="CamNang">Cẩm nang</a></li>
                    <li class="nav-item"><a class="nav-link nav-link-custom" asp-controller="Home" asp-action="FAQ">Hỏi đáp</a></li>
                    <li class="nav-item"><a class="nav-link nav-link-custom" asp-controller="Home" asp-action="OrderTracking">Tra cứu đơn hàng</a></li>
                </ul>

                <div class="auth-group">
                    <button class="header-icon" onclick="openSearch()" title="Tìm kiếm">
                        <i class="bi bi-search"></i>
                    </button>

                    @{
                        var count = HttpContextAccessor.HttpContext.Session.GetInt32("CartCount") ?? 0;
                    }
                    <a class="header-icon position-relative" asp-controller="Cart" asp-action="Index" title="Giỏ hàng">
                        <i class="bi bi-handbag"></i>
                        @if (count > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">@count</span>
                        }
                    </a>

                </div>
            </div>
        </div>
    </nav>

    <main role="main">@RenderBody()</main>

    <footer class="footer-camping pt-5 pb-3 border-top mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <h5 class="fw-bold mb-3 d-flex align-items-center"><i class="bi bi-tent me-2 fs-3"></i> CAMPING RENTAL</h5>
                    <p class="text-muted small lh-lg">Chúng tôi đồng hành cùng Châu và Trường trong dự án cung cấp thiết bị cắm trại cao cấp. Khám phá thiên nhiên theo cách chuyên nghiệp nhất.</p>
                    <div class="d-flex gap-2 mt-3">
                        <a href="http://facebook.com/truongg214" class="btn btn-outline-light btn-sm rounded-circle"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="btn btn-outline-light btn-sm rounded-circle"><i class="bi bi-instagram"></i></a>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6 text-center">
                    <h6 class="fw-bold mb-4 text-uppercase">Khám phá</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-3"><a asp-action="ProductList" class="text-decoration-none text-muted hover-white">Danh sách Lều</a></li>
                        <li class="mb-3"><a asp-action="DiaDiem" class="text-decoration-none text-muted hover-white">Địa điểm dã ngoại</a></li>
                        <li class="mb-3"><a asp-action="CamNang" class="text-decoration-none text-muted hover-white">Cẩm nang & Kinh nghiệm</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-6">
                    <h6 class="fw-bold mb-4 text-uppercase">Liên hệ ngay</h6>
                    <ul class="list-unstyled small text-muted lh-lg">
                        <li class="mb-2"><i class="bi bi-geo-alt text-white me-2"></i> Đại học Điện Lực (EPU), Hà Nội</li>
                        <li class="mb-2"><i class="bi bi-envelope text-white me-2"></i> contact@campingrental.vn</li>
                        <li class="mb-2"><i class="bi bi-telephone text-white me-2"></i> 0982.412.005</li>
                    </ul>
                </div>
            </div>
            <hr class="my-4" style="border-color: rgba(255,255,255,0.1);">
            <div class="row align-items-center">
                <div class="col-md-12 text-center">
                    <p class="text-muted small mb-0">&copy; 2026 Camping Rental. Proudly designed by <span class="text-white font-serif fst-italic fs-6">Hoàng Châu & Xuân Trường</span>.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function openSearch() {
            document.getElementById("searchOverlay").style.display = "block";
            setTimeout(() => { document.getElementById("searchInputLuxury").focus(); }, 100);
        }

        function closeSearch() {
            document.getElementById("searchOverlay").style.display = "none";
            $("#searchSuggestions").empty();
        }

        document.addEventListener('keydown', function(event) {
            if (event.key === "Escape") closeSearch();
        });

        $(document).ready(function () {
            $("#searchInputLuxury").on("input", function () {
                var keyword = $(this).val();
                if (keyword.length > 1) {
                    $.ajax({
                        url: '/Home/GetSuggestions',
                        data: { term: keyword },
                        success: function (data) {
                            var html = "";
                            if(data.length > 0) {
                                data.forEach(item => {
                                    html += `
                                        <div class="col-6 col-md-2 suggestion-item">
                                            <a href="/Home/Details/${item.id}" class="text-decoration-none text-dark">
                                                <img src="${item.image}" class="img-fluid rounded-4 mb-3 shadow-sm" style="height: 120px; width: 100%; object-fit: cover;">
                                                <p class="small fw-bold mb-0 text-truncate font-serif">${item.name}</p>
                                            </a>
                                        </div>`;
                                });
                            }
                            $("#searchSuggestions").html(html);
                        }
                    });
                } else {
                    $("#searchSuggestions").empty();
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <div class="floating-chat">
        <a href="tel:0982412005" class="chat-btn phone-btn shadow-lg">
            <i class="bi bi-telephone"></i>
            <span class="tooltip-text">Gọi Hotline ngay</span>
        </a>

        <a href="https://zalo.me/0982412005" target="_blank" class="chat-btn zalo-btn shadow-lg">
            <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/9/91/Icon_of_Zalo.svg/1200px-Icon_of_Zalo.svg.png" alt="Zalo">
            <span class="tooltip-text">Chat với Châu & Trường</span>
        </a>
    </div>
</body>
</html>