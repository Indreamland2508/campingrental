@model IEnumerable<BAOCAOWEBNANGCAO.Models.Combo>

@{
    ViewData["Title"] = "Quản lý Combo";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Ép vào khung Admin
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-success fw-bold">Danh sách Combo trọn gói</h2>
        <a asp-action="Create" class="btn btn-success fw-bold shadow-sm">
            <i class="bi bi-plus-circle me-2"></i> Thêm Combo mới
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-success">
                    <tr>
                        <th width="100">Hình ảnh</th>
                        <th>Tên Combo</th>
                        <th>Giá thuê</th>
                        <th>Các món bao gồm</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/no-image.png" : item.ImageUrl)" 
                                         style="width: 80px; height: 60px; object-fit: cover; border-radius: 8px;" />
                                </td>
                                <td>
                                    <strong class="text-dark">@item.Name</strong>
                                    @if (!string.IsNullOrEmpty(item.Badge))
                                    {
                                        <span class="badge bg-danger ms-1">@item.Badge</span>
                                    }
                                </td>
                                <td class="text-danger fw-bold">@item.Price.ToString("N0") ₫</td>
                                <td>
                                    <ul class="mb-0 ps-3 small text-muted" style="list-style-type: square;">
                                        @if (item.ComboDetails != null)
                                        {
                                            foreach (var detail in item.ComboDetails)
                                            {
                                                <li>@detail.Product.Name (x@detail.Quantity)</li>
                                            }
                                        }
                                    </ul>
                                </td>
                                <td class="text-center">
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success rounded-pill">Đang hiện</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill">Đang ẩn</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a href="#" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil-square"></i></a>
                                    <a href="#" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">Chưa có gói Combo nào được tạo.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>