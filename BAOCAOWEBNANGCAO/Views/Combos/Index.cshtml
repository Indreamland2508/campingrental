@model IEnumerable<BAOCAOWEBNANGCAO.Models.Combo>

@{
    ViewData["Title"] = "Quản lý Combo";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Ép vào khung Admin
}

<div class="container-fluid mt-4">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> <strong>Thành công!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> <strong>Lỗi:</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-success fw-bold">Danh sách Combo trọn gói</h2>
        <a asp-action="Create" class="btn btn-success fw-bold shadow-sm">
            <i class="bi bi-plus-circle me-2"></i> Thêm Combo mới
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-success">
                    <tr>
                        <th width="100">Hình ảnh</th>
                        <th>Tên Combo</th>
                        <th>Giá thuê</th>
                        <th>Các món bao gồm</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/no-image.png" : item.ImageUrl)"
                                         style="width: 80px; height: 60px; object-fit: cover; border-radius: 8px;" />
                                </td>
                                <td>
                                    <strong class="text-dark">@item.Name</strong>
                                    @if (!string.IsNullOrEmpty(item.Badge))
                                    {
                                        <span class="badge bg-danger ms-1">@item.Badge</span>
                                    }
                                </td>
                                <td class="text-danger fw-bold">@item.Price.ToString("N0") ₫</td>
                                <td>
                                    <ul class="mb-0 ps-3 small text-muted" style="list-style-type: square;">
                                        @if (item.ComboDetails != null)
                                        {
                                            foreach (var detail in item.ComboDetails)
                                            {
                                                <li>@detail.Product.Name (x@detail.Quantity)</li>
                                            }
                                        }
                                    </ul>
                                </td>
                                <td class="text-center">
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success rounded-pill">Đang hiện</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill">Đang ẩn</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Sửa Combo">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <button type="button" class="btn btn-sm btn-outline-danger btn-delete-combo-swal"
                                            data-combo-id="@item.Id"
                                            data-combo-name="@item.Name"
                                            title="Xóa Combo">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">Chưa có gói Combo nào được tạo.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // "Bắt quả tang" sự kiện bấm vào bất kỳ cái nút xóa nào có class 'btn-delete-combo-swal'
            $('.btn-delete-combo-swal').on('click', function(e) {
                // Ngăn chặn hành động mặc định (để nó không xóa luôn)
                e.preventDefault();

                // Lấy ra tên và ID của combo từ các data- attribute chúng ta gắn ở HTML
                const comboName = $(this).data('combo-name');
                const comboId = $(this).data('combo-id');

                // === BẮT ĐẦU SHOW THÔNG BÁO CỰC NGẦU GẦN GIỮA MÀN HÌNH ===
                Swal.fire({
                    title: '<h3 class="text-danger fw-bold font-serif mt-2">XÁC NHẬN XÓA?</h3>',
                    html: `Bạn có CHẮC CHẮN muốn xóa Gói Combo<br><strong>[ ${comboName} ]</strong> không?<br><small class="text-muted fst-italic">Hành động này không thể hoàn tác.</small>`,
                    icon: 'warning', // Icon cảnh báo màu vàng
                    showCancelButton: true, // Hiện nút Hủy
                    confirmButtonColor: '#dc3545', // Màu đỏ cho nút Xác nhận (trùng màu nút xóa)
                    cancelButtonColor: '#6c757d', // Màu xám cho nút Hủy
                    confirmButtonText: 'CÓ, XÓA NGAY!',
                    cancelButtonText: 'Hủy bỏ',
                    position: 'center', // Hiện ở giữa màn hình (mặc định rồi)
                    backdrop: `rgba(26, 58, 40, 0.4)` // Hiệu ứng làm mờ nền màu forest-dark
                }).then((result) => {
                    // Nếu nhân viên bấm "CÓ, XÓA NGAY!"
                    if (result.isConfirmed) {
                        // Tự động tạo một cái form "ma" và bắn lệnh POST lên Server để xóa
                        // LƯU Ý: Đường dẫn '/Combos/Delete/' này phải khớp với Controller của bạn
                        $.ajax({
                            url: '/Combos/Delete/' + comboId,
                            type: 'POST',
                            headers: {
                                "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val() // Gửi kèm token chống giả mạo
                            },
                            success: function(response) {
                                // Xóa xong, hiện thông báo chúc mừng
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Đã Xóa!',
                                    text: `Gói Combo [ ${comboName} ] đã biến mất khỏi hệ thống.`,
                                    timer: 1500, // Tự tắt sau 1.5 giây
                                    showConfirmButton: false
                                }).then(() => {
                                    window.location.reload(); // Reload lại trang để cập nhật bảng
                                });
                            },
                            error: function() {
                                // Nếu có lỗi (rớt mạng...), báo lỗi
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Lỗi!',
                                    text: 'Đã xảy ra lỗi khi xóa. Vui lòng thử lại sau.'
                                });
                            }
                        });
                    }
                });
            });
        });
    </script>
}