@using Microsoft.AspNetCore.Identity
@model IdentityUser

@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    /* Thêm hiệu ứng bừng sáng cho Avatar */
    .avatar-wrapper {
        position: relative;
        display: inline-block;
    }

    .avatar-img {
        border: 5px solid #eaf5ea; /* Viền xanh lá nhạt đồng bộ theme */
        transition: all 0.4s ease;
    }

    .avatar-wrapper:hover .avatar-img {
        transform: scale(1.05);
        box-shadow: 0 15px 35px rgba(26, 58, 40, 0.2) !important;
        border-color: #198754;
    }

    /* Tút lại nút đổi mật khẩu */
    .btn-outline-forest {
        color: #1a3a28;
        border-color: #1a3a28;
        font-weight: 600;
    }

        .btn-outline-forest:hover {
            background-color: #1a3a28;
            color: white;
        }
</style>

<div class="container-fluid mt-3">
    <div class="row mb-4">
        <div class="col-12">
            <h3 class="fw-bold text-secondary"><i class="bi bi-person-vcard me-2"></i>Hồ Sơ Của Tôi</h3>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-xl-4 col-lg-5 mb-4">
            <div class="card shadow-sm border-0 h-100" style="border-radius: 20px;">
                <div class="card-body text-center py-5">

                    <form asp-action="UpdateAvatar" method="post" enctype="multipart/form-data" id="avatarForm">
                        <div class="avatar-wrapper mb-4" style="position: relative; display: inline-block;">

                            <img src="/images/avatars/@(Model.Id).jpg"
                                 onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=@Model.UserName&background=1a3a28&color=fff&size=160&bold=true';"
                                 class="rounded-circle shadow-lg avatar-img"
                                 style="width: 160px; height: 160px; object-fit: cover;" alt="Avatar">

                            <label for="avatarInput" title="Đổi ảnh đại diện"
                                   style="position: absolute; bottom: 5px; right: 10px; background: #198754; color: white; border-radius: 50%; width: 45px; height: 45px; display: flex; align-items: center; justify-content: center; cursor: pointer; border: 4px solid white; transition: 0.3s;"
                                   onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                                <i class="bi bi-camera-fill fs-5"></i>
                            </label>

                            <input type="file" id="avatarInput" name="avatarFile" accept="image/png, image/jpeg, image/jpg" hidden onchange="document.getElementById('avatarForm').submit();" />
                        </div>
                    </form>

                    <h4 class="fw-bold text-dark mb-1">@Model.UserName</h4>

                    <div class="mt-3 mb-4">
                        <span class="badge px-4 py-2 rounded-pill fs-6 shadow-sm" style="background-color: #198754;">
                            <i class="bi bi-shield-check me-1"></i> @ViewBag.RoleName
                        </span>
                    </div>

                    <hr class="text-muted my-4 opacity-25">

                    <div class="d-grid gap-2 px-4">
                        <button class="btn btn-outline-forest rounded-pill py-2">
                            <i class="bi bi-key me-2"></i> Đổi mật khẩu
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-8 col-lg-7 mb-4">
            <div class="card shadow-sm border-0 h-100" style="border-radius: 20px;">
                <div class="card-header bg-white py-4 border-bottom-0" style="border-radius: 20px 20px 0 0;">
                    <h5 class="m-0 fw-bold" style="color: #1a3a28;"><i class="bi bi-pencil-square me-2"></i>Chi tiết tài khoản</h5>
                </div>
                <div class="card-body px-4 pb-4">
                    <form asp-action="UpdateProfile" method="post">
                        <div class="row mb-4">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <label class="form-label text-muted fw-bold small text-uppercase">Email đăng nhập</label>
                                <input type="email" class="form-control bg-light border-0" value="@Model.Email" readonly style="border-radius: 12px; padding: 12px 15px;">
                                <div class="form-text mt-2"><i class="bi bi-info-circle text-primary"></i> Không thể thay đổi Email đăng nhập.</div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label text-muted fw-bold small text-uppercase">Số điện thoại</label>
                                <input type="text" name="phoneNumber" class="form-control shadow-sm" value="@Model.PhoneNumber" placeholder="Nhập số điện thoại..." style="border-radius: 12px; padding: 12px 15px; border-color: #eaf5ea;">
                            </div>
                        </div>

                        <div class="row mb-5">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <label class="form-label text-muted fw-bold small text-uppercase mb-2">Trạng thái xác thực</label>
                                <div class="p-3 bg-light rounded-3" style="border-radius: 12px !important;">
                                    @if (Model.EmailConfirmed)
                                    {
                                        <span class="text-success fw-bold"><i class="bi bi-check-circle-fill me-2 fs-5 align-middle"></i> Đã kích hoạt</span>
                                    }
                                    else
                                    {
                                        <span class="text-warning fw-bold"><i class="bi bi-exclamation-circle-fill me-2 fs-5 align-middle"></i> Chưa kích hoạt</span>
                                    }
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label text-muted fw-bold small text-uppercase">ID Hệ thống</label>
                                <input type="text" class="form-control bg-light text-muted border-0" value="@Model.Id" readonly style="border-radius: 12px; padding: 12px 15px; font-size: 0.85rem;">
                            </div>
                        </div>

                        <hr class="text-muted mb-4 opacity-25">

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-success px-4 py-2 fw-bold rounded-pill shadow-sm" style="background-color: #198754;">
                                <i class="bi bi-floppy me-2"></i> Lưu Thay Đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>