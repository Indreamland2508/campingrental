@{
    ViewData["Title"] = "Thêm Nhân Viên Mới";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; 
}

<style>
    /* Card hiện đại bo góc sâu */
    .create-card {
        border-radius: 24px;
        border: none;
        box-shadow: 0 10px 40px rgba(0,0,0,0.05);
        background-color: #fff;
    }

    /* Tiêu đề form */
    .form-label {
        font-weight: 600;
        color: #495057;
        margin-bottom: 8px;
        font-size: 0.9rem;
    }

    /* Ô nhập liệu tinh tế */
    .form-control {
        border-radius: 12px;
        padding: 12px 15px;
        border: 1px solid #e9ecef;
        background-color: #f8f9fa;
        transition: all 0.2s;
    }

        .form-control:focus {
            background-color: #fff;
            border-color: #198754; /* Màu xanh lá đặc trưng của Camping Rental */
            box-shadow: 0 0 0 4px rgba(25, 135, 84, 0.1);
        }

    /* Nút bấm Gradient */
    .btn-create-account {
        background: linear-gradient(135deg, #198754 0%, #157347 100%);
        color: white;
        border: none;
        border-radius: 50rem;
        padding: 12px 30px;
        font-weight: 700;
        transition: all 0.3s;
    }

        .btn-create-account:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(25, 135, 84, 0.2);
            color: white;
        }

    .btn-back-list {
        border-radius: 50rem;
        padding: 12px 25px;
        font-weight: 600;
    }

    /* Icon trang trí trong ô nhập */
    .input-group-text {
        background-color: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 12px 0 0 12px !important;
        color: #6c757d;
    }

    .form-control-with-icon {
        border-radius: 0 12px 12px 0 !important;
        border-left: none;
    }
</style>

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-lg-6 col-md-8 mx-auto">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold text-dark m-0"><i class="bi bi-person-plus text-success me-2"></i> Thêm Nhân Viên</h2>
                    <p class="text-muted small m-0">Tạo tài khoản mới cho nhân viên quản lý hệ thống</p>
                </div>
                <a asp-action="Index" class="btn btn-light rounded-pill px-4 border shadow-sm">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                </a>
            </div>

            <div class="card create-card">
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="All" class="text-danger small mb-4"></div>

                        <div class="mb-4">
                            <label class="form-label">Email đăng nhập</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input type="email" name="email" class="form-control form-control-with-icon"
                                       placeholder="ví dụ: nhanvien@camping.com" required />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Mật khẩu ban đầu</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-shield-lock"></i></span>
                                <input type="password" name="password" id="passwordInput" class="form-control border-start-0 border-end-0"
                                       placeholder="••••••••" required />
                                <button class="btn btn-outline-secondary border-start-0 bg-light" type="button" id="togglePassword"
                                        style="border-radius: 0 12px 12px 0 !important; border: 1px solid #e9ecef;">
                                    <i class="bi bi-eye" id="eyeIcon"></i>
                                </button>
                            </div>
                            <small class="text-muted mt-1 d-block"><i class="bi bi-info-circle me-1"></i> Nên bao gồm chữ hoa, chữ thường và ký tự đặc biệt.</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Số điện thoại</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                <input type="text" name="phoneNumber" class="form-control form-control-with-icon"
                                       placeholder="Nhập số điện thoại liên lạc..." />
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top">
                            <a asp-action="Index" class="btn btn-light btn-back-list border">Hủy bỏ</a>
                            <button type="submit" class="btn btn-create-account shadow">
                                <i class="bi bi-check-circle me-2"></i> Tạo tài khoản
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
@section Scripts {
    <script>
        const togglePassword = document.querySelector('#togglePassword');
        const passwordInput = document.querySelector('#passwordInput');
        const eyeIcon = document.querySelector('#eyeIcon');

        togglePassword.addEventListener('click', function (e) {
            // Thay đổi kiểu dữ liệu từ password sang text và ngược lại
            const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordInput.setAttribute('type', type);

            // Thay đổi icon con mắt (eye / eye-slash)
            eyeIcon.classList.toggle('bi-eye');
            eyeIcon.classList.toggle('bi-eye-slash');
        });
    </script>
}