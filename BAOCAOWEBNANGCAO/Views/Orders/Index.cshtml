@model IEnumerable<BAOCAOWEBNANGCAO.Models.Order>

@{
    ViewData["Title"] = "Quản lý đơn thuê";
    Layout = "_AdminLayout";
}

<style>
    /* Card Header với dải màu Gradient xanh rừng sâu đồng bộ Sidebar */
    .card-header-forest {
        background: linear-gradient(135deg, #1a3a28 0%, #2e5a40 100%);
        color: white;
        border-radius: 20px 20px 0 0 !important;
        padding: 1.25rem;
    }

    /* Tinh chỉnh bảng cho thông thoáng và hiện đại */
    .table-modern {
        border-radius: 15px;
        overflow: hidden;
    }

        .table-modern thead th {
            background-color: #f8faf9;
            color: #4b5563;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-weight: 700;
            border: none;
            padding: 15px;
        }

        .table-modern tbody td {
            padding: 15px;
            vertical-align: middle;
        }

    /* Các Badge trạng thái "sang" hơn */
    .badge-status {
        padding: 8px 12px;
        border-radius: 50rem;
        font-weight: 700;
        font-size: 0.7rem;
        text-transform: uppercase;
        display: inline-block;
        text-align: center;
        min-width: 90px;
    }

    /* Trạng thái Giao nhận */
    .status-pending {
        background-color: #fff4e6;
        color: #d97706;
    }
    /* Chờ duyệt */
    .status-approved {
        background-color: #e0f2fe;
        color: #0369a1;
    }
    /* Đang thuê */
    .status-completed {
        background-color: #eaf5ea;
        color: #157347;
    }
    /* Hoàn thành */
    .status-cancelled {
        background-color: #fee2e2;
        color: #dc2626;
    }
    /* Đã hủy */

    /* TRẠNG THÁI TIỀN NONG (Mới thêm) */
    .payment-unpaid {
        background-color: #fee2e2;
        color: #dc2626;
        border: 1px solid #fca5a5;
    }

    .payment-deposited {
        background-color: #fef9c3;
        color: #ca8a04;
        border: 1px solid #fde047;
    }

    .payment-paid {
        background-color: #dcfce7;
        color: #16a34a;
        border: 1px solid #86efac;
    }

    /* Nút thao tác bo tròn viên thuốc */
    .btn-action {
        border-radius: 50rem;
        font-weight: 600;
        padding: 5px 15px;
        transition: all 0.2s;
    }
</style>

<div class="container-fluid px-4 mt-4 mb-5">
    <div class="mb-4">
        <h2 class="fw-bold text-dark m-0"><i class="bi bi-receipt-cutoff text-success me-2"></i> Quản lý Đơn thuê lều</h2>
        <p class="text-muted small">Kiểm soát giao nhận và thanh toán cọc từ khách hàng</p>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 20px;">
        <div class="card-header-forest d-flex align-items-center">
            <i class="bi bi-table me-2"></i>
            <h6 class="m-0 fw-bold">Danh sách đơn hàng mới</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 table-modern align-middle">
                    <thead>
                        <tr>
                            <th class="ps-4">Mã đơn</th>
                            <th>Khách hàng & Ngày</th>
                            <th>Tài chính (Cọc 50%)</th>
                            <th class="text-center">Thanh toán</th>
                            <th class="text-center">Giao nhận</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderByDescending(o => o.OrderDate))
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark fs-5">#@item.Id</td>

                                <td>
                                    <div class="fw-bold text-dark">@item.CustomerName</div>
                                    <div class="text-muted small"><i class="bi bi-telephone-fill me-1"></i>@item.CustomerPhone</div>
                                    <div class="text-muted small mt-1"><i class="bi bi-clock me-1"></i>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                                </td>

                                <td>
                                    <div class="small">Tổng: <span class="fw-bold text-dark">@item.TotalAmount.ToString("#,##0")₫</span></div>
                                    <div class="small mt-1">Đã cọc: <span class="fw-bold text-warning">@item.DepositAmount.ToString("#,##0")₫</span></div>
                                    <div class="small mt-1">Thu nốt: <span class="fw-bold text-danger">@item.RemainingAmount.ToString("#,##0")₫</span></div>
                                </td>

                                <td class="text-center">
                                    @if (item.PaymentStatus == "Paid")
                                    {
                                        <span class="badge-status payment-paid"><i class="bi bi-check-circle-fill me-1"></i>Thu đủ</span>
                                    }
                                    else if (item.PaymentStatus == "Deposited")
                                    {
                                        <span class="badge-status payment-deposited"><i class="bi bi-shield-lock-fill me-1"></i>Đã cọc</span>
                                    }
                                    else
                                    {
                                        <span class="badge-status payment-unpaid"><i class="bi bi-exclamation-circle-fill me-1"></i>Chưa cọc</span>
                                    }
                                </td>

                                <td class="text-center">
                                    @if (item.Status == "Pending")
                                    {
                                        <span class="badge-status status-pending">Chờ duyệt</span>
                                    }
                                    else if (item.Status == "Approved" || item.Status == "Delivering")
                                    {
                                        <span class="badge-status status-approved">Đang thuê</span>
                                    }
                                    else if (item.Status == "Completed")
                                    {
                                        <span class="badge-status status-completed">Hoàn thành</span>
                                    }
                                    else if (item.Status == "Cancelled")
                                    {
                                        <span class="badge-status status-cancelled">Đã hủy</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary badge-status">@item.Status</span>
                                    }
                                </td>

                                <td class="text-end pe-4">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light btn-action text-primary me-1 border shadow-sm">
                                        <i class="bi bi-eye"></i> Xử lý
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-light btn-action text-danger border shadow-sm">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>