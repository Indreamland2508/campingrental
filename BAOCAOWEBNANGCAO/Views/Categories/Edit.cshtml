@model BAOCAOWEBNANGCAO.Models.Category
@{
    ViewData["Title"] = "Quản lý Danh mục";
    Layout = "_AdminLayout";
}
<div class="card shadow-sm border-0 p-4" style="border-radius: 20px;">
    <h3 class="fw-bold mb-4">✏ Chỉnh sửa danh mục</h3>

    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="Name" class="form-label fw-bold">Tên danh mục</label>
            <input asp-for="Name" class="form-control rounded-pill px-3" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
            <textarea asp-for="Description" class="form-control" style="border-radius: 15px;" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-success px-4 rounded-pill fw-bold">
                <i class="bi bi-save me-1"></i> Lưu thay đổi
            </button>
            <a asp-action="Index" class="btn btn-light px-4 rounded-pill border">Hủy bỏ</a>
        </div>
    </form>
</div>