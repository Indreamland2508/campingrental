@model IEnumerable<BAOCAOWEBNANGCAO.Models.Product>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
    Layout = "_AdminLayout";
}
@{
    var lowStock = Model.Where(p => p.Quantity <= 3 && p.Quantity > 0).ToList();
}

<style>
    /* Giữ phong cách bảng hiện đại */
    .table-modern thead th {
        background-color: #f8f9fa;
        color: #6c757d;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        border: none;
        padding: 1.25rem;
    }

    .table-modern tbody td {
        padding: 1.25rem;
        vertical-align: middle;
        border-bottom: 1px solid #f1f3f5;
    }

    .img-product {
        border-radius: 12px;
        object-fit: cover;
        box-shadow: 0 4px 8px rgba(0,0,0,0.05);
    }

    .search-box {
        border-radius: 50rem;
        padding-left: 1.5rem;
        box-shadow: 0 4px 10px rgba(0,0,0,0.03);
    }

    .btn-action {
        border-radius: 10px;
        width: 38px;
        height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
</style>

<div class="container-fluid px-4 mt-4">
    <div class="row align-items-center mb-4">
        <div class="col-md-5">
            <h2 class="fw-bold text-dark m-0">📦 Quản lý kho hàng</h2>
            <p class="text-muted small m-0">Theo dõi số lượng lều và dụng cụ cắm trại</p>
        </div>
        <div class="col-md-4">
            <form method="get" class="d-flex">
                <div class="input-group bg-white rounded-pill shadow-sm overflow-hidden">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control border-0 px-4" placeholder="Tìm tên sản phẩm..." />
                    <button class="btn btn-white text-success border-0" type="submit"><i class="bi bi-search"></i></button>
                </div>
            </form>
        </div>
        <div class="col-md-3 text-end">
            <a asp-action="Create" class="btn btn-success rounded-pill px-4 fw-bold shadow-sm">
                <i class="bi bi-plus-lg me-1"></i> Thêm mới
            </a>
        </div>
    </div>

    @if (lowStock.Any())
    {
        <div class="alert alert-warning border-0 shadow-sm mb-4 d-flex align-items-center" style="border-radius: 15px;">
            <i class="bi bi-exclamation-triangle-fill fs-4 me-3 text-warning"></i>
            <div>
                <strong class="d-block text-dark">⚠ Cảnh báo tồn kho thấp!</strong>
                <div class="mt-1">
                    @foreach (var item in lowStock)
                    {
                        <span class="badge bg-danger rounded-pill me-1 fw-normal">@item.Name: @item.Quantity chiếc</span>
                    }
                </div>
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 20px;">
        <div class="table-responsive">
            <table class="table table-modern mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Sản phẩm</th>
                        <th>Danh mục</th>
                        <th>Giá thuê</th>
                        <th>Kho</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    @{
                                        var imgSrc = string.IsNullOrEmpty(item.ImageUrl) ? "/images/no-image.png" :
                                        (item.ImageUrl.StartsWith("/") ? item.ImageUrl : "/" + item.ImageUrl);
                                    }
                                    <img src="@imgSrc" class="img-product me-3" style="width: 60px; height: 45px;" />
                                    <div>
                                        <div class="fw-bold text-dark">@item.Name</div>
                                        <div class="text-muted extra-small">ID: #@item.Id</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="text-secondary small">@item.Category?.Name</span></td>
                            <td class="fw-bold text-success">@item.PricePerDay.ToString("#,##0")đ</td>
                            <td><span class="fw-medium">@item.Quantity</span></td>
                            <td>
                                @if (item.Quantity == 0)
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-2 py-1 small">Hết hàng</span>
                                }
                                else if (item.Quantity <= 3)
                                {

                                    <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-2 py-1 small">Sắp hết</span>
                                }
                                else
                                {

                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-2 py-1 small">Sẵn sàng</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a href="javascript:void(0)"
                                   onclick="window.location.href='/Products/Edit/@item.Id'"
                                   class="btn btn-sm btn-warning rounded-pill px-3 shadow-sm"
                                   style="cursor: pointer !important; position: relative; z-index: 9999;">
                                    <i class="bi bi-pencil-square me-1"></i> Sửa
                                </a>

                                <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3 delete-btn"
                                        data-id="@item.Id" data-name="@item.Name">
                                    <i class="bi bi-trash3"></i> Xóa
                                </button>

                                <form id="delete-form-@item.Id" asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:none;">
                                    @Html.AntiForgeryToken()
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white border-top py-3 px-4">
            <div class="row align-items-center">
                <div class="col-sm-6 text-muted small">
                    Trang @ViewBag.CurrentPage / @ViewBag.TotalPages (@ViewBag.TotalItems sản phẩm)
                </div>
                <div class="col-sm-6 text-end">
                    <ul class="pagination pagination-sm mb-0 justify-content-end">
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "") mx-1">
                                <a class="page-link border-0 rounded shadow-sm" href="?page=@i&search=@ViewBag.Search">@i</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            // Sử dụng $(document).on để tránh lỗi khi chuyển trang phân trang
            $(document).on('click', '.delete-btn', function () {
                const id = $(this).data('id');
                const name = $(this).data('name');

                Swal.fire({
                    title: 'Xác nhận xóa?',
                    text: `Châu và Trường chắc chắn muốn xóa "${name}" chứ?`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Đúng, xóa ngay!',
                    cancelButtonText: 'Để xem lại'
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Tìm đúng ID form và gửi lệnh đi
                        document.getElementById(`delete-form-${id}`).submit();
                    }
                });
            });
        });
    </script>
}