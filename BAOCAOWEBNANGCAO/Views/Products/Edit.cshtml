@model BAOCAOWEBNANGCAO.Models.Product

@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .edit-card {
        border-radius: 24px;
        border: none;
        box-shadow: 0 10px 40px rgba(0,0,0,0.05);
    }

    .form-label {
        font-weight: 600;
        color: #495057;
        font-size: 0.9rem;
        margin-bottom: 8px;
    }

    .form-control, .form-select {
        border-radius: 12px;
        padding: 12px 15px;
        border: 1px solid #e9ecef;
        background-color: #f8f9fa;
        transition: all 0.3s;
    }

        .form-control:focus, .form-select:focus {
            background-color: #fff;
            border-color: #198754;
            box-shadow: 0 0 0 4px rgba(25, 135, 84, 0.1);
        }

    .img-preview-box {
        background: #f8f9fa;
        border-radius: 15px;
        padding: 15px;
        border: 1px dashed #dee2e6;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-save {
        background: linear-gradient(135deg, #198754 0%, #157347 100%);
        border: none;
        border-radius: 50rem;
        padding: 12px 30px;
        font-weight: 700;
        color: white;
        transition: all 0.3s;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(25, 135, 84, 0.2);
            color: white;
        }
</style>

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-lg-9 mx-auto">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h3 class="fw-bold text-dark m-0">✏ Chỉnh sửa sản phẩm</h3>
                    <p class="text-muted small m-0">Đang chỉnh sửa: <span class="text-success fw-bold">@Model.Name</span></p>
                </div>
                <a asp-action="Index" class="btn btn-light rounded-pill px-4 border shadow-sm">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                </a>
            </div>
            

            
            <div class="card edit-card">
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4 small"></div>

                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ImageUrl" />

                        <div class="row">
                            <div class="col-md-12 mb-4">
                                <label asp-for="Name" class="form-label">Tên sản phẩm</label>
                                <input asp-for="Name" class="form-control" placeholder="Ví dụ: Lều Vintage 4 người..." />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-4">
                                <label asp-for="Description" class="form-label">Mô tả sản phẩm</label>
                                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả chi tiết..."></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="PricePerDay" class="form-label">Giá thuê / ngày (VNĐ)</label>
                                <div class="input-group">
                                    <input asp-for="PricePerDay" class="form-control" />
                                    <span class="input-group-text bg-white">₫</span>
                                </div>
                                <span asp-validation-for="PricePerDay" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="Quantity" class="form-label">Số lượng trong kho</label>
                                <input asp-for="Quantity" class="form-control" />
                                <span asp-validation-for="Quantity" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-4">
                                <label asp-for="CategoryId" class="form-label">Danh mục sản phẩm</label>
                                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label class="form-label d-block">Hình ảnh hiện tại</label>
                                <div class="img-preview-box shadow-sm">
                                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                    {
                                        <img src="@(Model.ImageUrl.StartsWith("/") ? Model.ImageUrl : "/" + Model.ImageUrl)"
                                             class="img-fluid rounded-3"
                                             style="max-height: 180px; object-fit: contain;"
                                             id="imgPreview" />
                                    }
                                    else
                                    {
                                        <div class="text-muted py-4 small" id="imgPlaceholder">
                                            <i class="bi bi-image fs-1 d-block mb-2"></i>
                                            Chưa có ảnh
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label class="form-label">Tải lên ảnh mới</label>
                                <div class="p-4 border rounded-3 bg-light text-center h-100 d-flex flex-column justify-content-center" style="border-style: dashed !important;">
                                    <i class="bi bi-cloud-arrow-up fs-2 text-success mb-2"></i>
                                    <input type="file" name="imageFile" id="imageInput" class="form-control border-0 bg-transparent" accept="image/*" />
                                    <p class="text-muted extra-small m-0 mt-2">Để trống nếu muốn giữ nguyên ảnh cũ</p>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-4 pt-4 border-top">
                            <a asp-action="Index" class="btn btn-light rounded-pill px-4 border">Hủy bỏ</a>
                            <button type="submit" class="btn btn-success btn-save">
                                <i class="bi bi-check-lg me-2"></i> Xác nhận thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Hiển thị ảnh ngay khi chọn file
        document.getElementById('imageInput').onchange = function (evt) {
            const [file] = this.files;
            if (file) {
                const imgPreview = document.getElementById('imgPreview');
                if(imgPreview) {
                    imgPreview.src = URL.createObjectURL(file);
                } else {
                    // Nếu trước đó chưa có ảnh, tạo thẻ img mới
                    const box = document.querySelector('.img-preview-box');
                    box.innerHTML = `<img src="${URL.createObjectURL(file)}" class="img-fluid rounded-3" style="max-height: 180px; object-fit: contain;" id="imgPreview" />`;
                }
            }
        };
    </script>
}