@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container py-5 text-center">
    <div class="card border-0 shadow-lg p-5 mx-auto" style="max-width: 600px; border-radius: 30px;">
        <div class="mb-4">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
        </div>

        <h2 class="fw-bold text-dark mb-3">Đặt thuê lều thành công!</h2>
        <p class="text-muted mb-4 px-lg-4">
            Cảm ơn Châu đã tin tưởng dịch vụ của **Camping Rental**. Đơn hàng của bạn đã được hệ thống ghi nhận. Nhân viên sẽ liên hệ xác nhận trong vòng 15 phút tới.
        </p>

        <div class="bg-light rounded-4 p-3 mb-4 text-start">
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted small">Trạng thái:</span>
                <span class="badge bg-success-subtle text-success rounded-pill">Đang chờ xác nhận</span>
            </div>
            <div class="d-flex justify-content-between">
                <span class="text-muted small">Thời gian cắm trại:</span>
                <span class="fw-bold small">Cập nhật trong mail</span>
            </div>
        </div>

        <div class="d-grid gap-2">
            <a asp-controller="Home" asp-action="Index" class="btn btn-success rounded-pill py-3 fw-bold shadow">
                TIẾP TỤC KHÁM PHÁ
            </a>
            <p class="extra-small text-muted mt-2">Mọi thắc mắc vui lòng gọi: <span class="fw-bold">0123.456.789</span></p>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.5.1/dist/confetti.browser.min.js"></script>
<script>
    var duration = 3 * 1000;
    var end = Date.now() + duration;

    (function frame() {
      confetti({
        particleCount: 3,
        angle: 60,
        spread: 55,
        origin: { x: 0 },
        colors: ['#198754', '#ffffff']
      });
      confetti({
        particleCount: 3,
        angle: 120,
        spread: 55,
        origin: { x: 1 },
        colors: ['#198754', '#ffffff']
      });

      if (Date.now() < end) {
        requestAnimationFrame(frame);
      }
    }());
</script>