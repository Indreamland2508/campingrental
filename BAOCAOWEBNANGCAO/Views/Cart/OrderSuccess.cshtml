@model BAOCAOWEBNANGCAO.Models.Order

@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container mt-5 text-center mb-5">
    <div class="mb-4">
        <h1 class="text-success" style="font-size: 4rem;">✓</h1>
    </div>
    <h2 class="text-success fw-bold">🎉 Đặt hàng thành công!</h2>
    <p class="fs-5">Mã đơn hàng của bạn là: <strong class="text-primary">#@Model.Id</strong></p>

    <div class="card mx-auto shadow-lg border-0 mt-4" style="max-width: 500px; border-radius: 15px;">
        <div class="card-body p-4">
            <h4 class="card-title fw-bold mb-3">Hướng dẫn thanh toán tiền cọc</h4>
            <p class="text-muted mb-4">Vui lòng quét mã QR dưới đây để thanh toán <strong class="text-danger">50%</strong> tiền cọc. Hệ thống sẽ tự động xác nhận đơn hàng sau 1-2 phút.</p>

            @{
                // ⚠️ THAY THÔNG TIN TÀI KHOẢN CỦA BẠN VÀO ĐÂY NHÉ!
                string bankId = "MB"; // Mã ngân hàng (VD: MB, VCB, TCB, ACB...)
                string accountNo = "0982412582005"; // Số tài khoản ngân hàng của bạn
                string accountName = "NGUYEN HOANG CHAU"; // Tên chủ tài khoản (Viết hoa không dấu)

                // Nội dung chuyển khoản BẮT BUỘC phải là DH + Mã đơn hàng
                string transferContent = $"DH{Model.Id}";

                // Số tiền cọc (Ép kiểu về số nguyên để không bị lỗi số thập phân)
                long amountToPay = (long)Model.DepositAmount;

                // Tạo link ảnh QR từ API của VietQR
                string qrUrl = $"https://img.vietqr.io/image/{bankId}-{accountNo}-compact.png?amount={amountToPay}&addInfo={transferContent}&accountName={accountName}";
            }

            <img src="@qrUrl" alt="Mã QR Thanh Toán" class="img-fluid border rounded p-2 mb-4 shadow-sm" style="max-width: 250px;" />

            <div class="alert alert-light text-start border" style="background-color: #f8f9fa;">
                <p class="mb-2 fw-bold text-center text-dark">Hoặc chuyển khoản thủ công:</p>
                <hr class="mt-1 mb-2">
                <div class="d-flex justify-content-between mb-1">
                    <span class="text-muted">Ngân hàng:</span>
                    <strong>@bankId</strong>
                </div>
                <div class="d-flex justify-content-between mb-1">
                    <span class="text-muted">Số tài khoản:</span>
                    <strong>@accountNo</strong>
                </div>
                <div class="d-flex justify-content-between mb-1">
                    <span class="text-muted">Chủ tài khoản:</span>
                    <strong>@accountName</strong>
                </div>
                <div class="d-flex justify-content-between mb-1">
                    <span class="text-muted">Cần cọc (50%):</span>
                    <strong class="text-danger fs-5">@amountToPay.ToString("N0") VNĐ</strong>
                </div>
                <div class="d-flex justify-content-between mt-2">
                    <span class="text-muted">Nội dung CK:</span>
                    <strong class="text-primary fs-4 bg-light px-2 border border-primary rounded">@transferContent</strong>
                </div>
            </div>

            <div class="mt-4">
                <p class="text-muted small">
                    Trạng thái đơn: <span class="badge bg-warning text-dark">Chờ thanh toán cọc</span>
                </p>
                <p class="text-muted small">
                    Tiền mặt thu lúc nhận lều: <strong>@Model.RemainingAmount.ToString("N0") VNĐ</strong>
                </p>
                <a href="/" class="btn btn-outline-primary mt-2 rounded-pill px-5">Về trang chủ</a>
            </div>
        </div>
    </div>
</div>