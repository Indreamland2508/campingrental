@model BAOCAOWEBNANGCAO.Models.Order

@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container mt-5 text-center mb-5">
    <div class="mb-4">
        <i class="fas fa-check-circle text-success" style="font-size: 5rem;"></i>
    </div>
    <h1 class="text-success fw-bold">Thanh toán thành công!</h1>
    <h4 class="mt-3">Cảm ơn bạn đã đặt thuê lều trại.</h4>

    <div class="card mx-auto shadow-sm border-0 mt-4" style="max-width: 500px; border-radius: 15px; background-color: #f8f9fa;">
        <div class="card-body p-4 text-start">
            <p class="fs-5 border-bottom pb-2">Mã đơn hàng: <strong class="text-primary float-end">#@Model.Id</strong></p>
            <p class="fs-5 border-bottom pb-2">Trạng thái: <strong class="text-success float-end">Đã nhận cọc</strong></p>
            <p class="fs-5 pt-2 mb-0">Tiền cần thu lúc nhận đồ: <strong class="text-danger float-end">@Model.RemainingAmount.ToString("N0") VNĐ</strong></p>
        </div>
    </div>

    <div class="mt-5">
        <p class="text-muted">Nhân viên của chúng tôi sẽ liên hệ với bạn trong thời gian sớm nhất để xác nhận giao hàng.</p>
        <a href="/" class="btn btn-primary rounded-pill px-5 py-2 mt-2">Tiếp tục mua sắm</a>
    </div>
</div>