@model List<BAOCAOWEBNANGCAO.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng của bạn";
    decimal totalAmount = Model.Sum(item => item.TotalPrice);
}

<style>
    :root {
        --forest-dark: #1a4d3a;
        --border-color: #e1e4e8;
    }

    .font-serif {
        font-family: 'Playfair Display', 'Times New Roman', serif;
    }

    /* Tiêu đề giỏ hàng */
    .cart-title {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--forest-dark);
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid var(--forest-dark);
        display: inline-block;
    }

    /* Bảng sản phẩm hiện đại */
    .cart-table th {
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 1px;
        color: #6c757d;
        border-bottom: 2px solid #eee;
        padding-bottom: 15px;
    }

    .cart-table td {
        padding: 20px 10px;
        border-bottom: 1px solid #f8f9fa;
        vertical-align: middle;
    }

    .cart-item-img {
        width: 90px;
        height: 90px;
        object-fit: cover;
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    .cart-item-name {
        font-size: 1.1rem;
        font-weight: 700;
        color: #212529;
        text-decoration: none;
        transition: 0.3s;
    }

        .cart-item-name:hover {
            color: var(--forest-dark);
        }

    /* Nút Xóa cực gọn */
    .btn-remove {
        color: #adb5bd;
        background: #f8f9fa;
        border-radius: 50%;
        width: 35px;
        height: 35px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .btn-remove:hover {
            background: #dc3545;
            color: #fff;
            transform: rotate(90deg);
        }

    /* Thẻ Tóm tắt trôi theo cuộn chuột (Sticky) */
    .summary-card {
        background-color: #f9fafb;
        border-radius: 20px;
        padding: 30px;
        position: sticky;
        top: 30px;
    }

    .btn-checkout {
        background-color: var(--forest-dark);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 15px;
        font-weight: 700;
        letter-spacing: 1px;
        transition: 0.3s;
    }

        .btn-checkout:hover {
            background-color: #113326;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(26, 77, 58, 0.2);
        }

    /* Empty state */
    .empty-cart-wrapper {
        padding: 80px 0;
        text-align: center;
    }
</style>

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-end mb-4">
        <h1 class="cart-title font-serif m-0">Giỏ hàng</h1>
        <span class="text-muted fw-bold mb-2">@Model.Count sản phẩm</span>
    </div>

    @if (Model.Count > 0)
    {
        <div class="row g-5">
            <div class="col-lg-8">
                <div class="table-responsive">
                    <table class="table cart-table mb-0">
                        <thead>
                            <tr>
                                <th colspan="2">Sản phẩm</th>
                                <th class="text-center">Đơn giá / Ngày</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end">Tạm tính</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td style="width: 110px;">
                                        <img src="@(string.IsNullOrEmpty(item.Product.ImageUrl) ? "/images/no-image.png" : item.Product.ImageUrl)" class="cart-item-img" alt="@item.Product.Name">
                                    </td>
                                    <td>
                                        <a href="/Home/Details/@item.Product.Id" class="cart-item-name d-block mb-1">@item.Product.Name</a>
                                        <span class="badge bg-light text-dark border">ID: #@item.Product.Id</span>
                                    </td>
                                    <td class="text-center fw-semibold text-muted">
                                        @item.Product.PricePerDay.ToString("#,##0") đ
                                    </td>
                                    <td class="text-center">
                                        <div class="d-inline-block border rounded px-3 py-1 fw-bold bg-white">
                                            @item.Quantity
                                        </div>
                                    </td>
                                    <td class="text-end fw-bold text-dark" style="font-size: 1.1rem;">
                                        @item.TotalPrice.ToString("#,##0") đ
                                    </td>
                                    <td class="text-end pe-0">
                                        <a asp-action="RemoveFromCart" asp-route-productId="@item.Product.Id" class="btn-remove" title="Xóa khỏi giỏ">
                                            <i class="bi bi-x-lg"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-4 pt-3 border-top">
                    <a asp-controller="Home" asp-action="ProductList" class="text-decoration-none text-muted fw-bold">
                        <i class="bi bi-arrow-left me-2"></i>Tiếp tục chọn đồ dã ngoại
                    </a>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="summary-card shadow-sm">
                    <h4 class="font-serif fw-bold border-bottom pb-3 mb-4">Tóm tắt</h4>

                    <div class="d-flex justify-content-between mb-3 text-muted">
                        <span>Tổng tiền lều/ngày:</span>
                        <span class="fw-semibold text-dark">@totalAmount.ToString("#,##0") đ</span>
                    </div>

                    <div class="d-flex justify-content-between mb-3 text-muted">
                        <span>Số ngày thuê:</span>
                        <span class="fst-italic">Chọn ở bước sau</span>
                    </div>

                    <hr class="my-4 opacity-25">

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="fw-bold text-uppercase" style="font-size: 0.9rem;">Tạm tính (1 ngày)</span>
                        <span class="fw-bold" style="font-size: 1.5rem; color: var(--forest-dark);">@totalAmount.ToString("#,##0") đ</span>
                    </div>

                    <a asp-action="Checkout" class="btn btn-checkout w-100 text-uppercase d-flex justify-content-between align-items-center">
                        <span>Chốt đơn thuê</span>
                        <i class="bi bi-arrow-right"></i>
                    </a>

                    <p class="text-center text-muted mt-3 mb-0" style="font-size: 0.8rem;">
                        <i class="bi bi-shield-check me-1"></i> Thanh toán an toàn và bảo mật
                    </p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="empty-cart-wrapper">
            <i class="bi bi-cart-x text-muted" style="font-size: 5rem; opacity: 0.3;"></i>
            <h2 class="font-serif fw-bold mt-4 mb-3">Giỏ hàng cắm trại đang trống</h2>
            <p class="text-muted mb-4 fs-5">Hành trình ngàn sao bắt đầu từ bước chuẩn bị đồ đạc. Hãy lấp đầy balo của bạn nhé!</p>
            <a asp-controller="Home" asp-action="ProductList" class="btn px-5 py-3 text-white fw-bold rounded-pill shadow" style="background-color: var(--forest-dark); letter-spacing: 1px;">
                KHÁM PHÁ ĐỒ DÃ NGOẠI
            </a>
        </div>
    }
</div>