@model IEnumerable<BAOCAOWEBNANGCAO.Models.Category>
@{
    ViewData["Title"] = "Quản lý Danh mục";
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0"><i class="bi bi-tags-fill text-success me-2"></i> Danh mục sản phẩm</h2>
        </div>
        <a asp-action="Create" class="btn btn-success px-4 py-2 fw-bold shadow-sm">
            <i class="bi bi-plus-lg me-2"></i>Thêm danh mục
        </a>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 20px;">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Tên danh mục</th>
                        <th>Mô tả</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@item.Name</td>
                            <td class="text-muted small">@item.Description</td>
                            <td class="text-end pe-4">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-light text-warning btn-sm border me-1">
                                    <i class="bi bi-pencil-square"></i>
                                </a>

                                <button type="button" class="btn btn-light text-danger btn-sm border"
                                        onclick="confirmDelete('@item.Id', '@item.Name')">
                                    <i class="bi bi-trash3"></i>
                                </button>

                                <form id="delete-form-@item.Id" asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:none;">
                                    @Html.AntiForgeryToken()
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(id, name) {
            Swal.fire({
                title: 'Xóa danh mục?',
                text: "Bạn có chắc chắn muốn xóa danh mục '" + name + "' không? Hành động này không thể hoàn tác!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Đúng, xóa ngay!',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    // Nếu bấm đồng ý, submit cái form ẩn tương ứng
                    document.getElementById('delete-form-' + id).submit();
                }
            })
        }
    </script>
}