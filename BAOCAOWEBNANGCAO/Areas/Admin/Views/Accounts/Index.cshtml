@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>
@{
    ViewData["Title"] = "Quản lý Tài khoản";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="~/css/Accounts.Index.css" />

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark m-0"><i class="bi bi-people-fill text-forest me-2"></i> Quản lý Tài khoản</h2>
            <p class="text-muted small m-0">Danh sách nhân viên và quyền truy cập hệ thống</p>
        </div>
        <a asp-action="Create" class="btn btn-forest rounded-pill px-4 py-2 fw-bold shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Thêm Nhân Viên Mới
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm mb-4" style="border-radius: 15px;">
            <i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["Error"]
        </div>
    }

    <div class="card border-0 shadow-sm" style="border-radius: 24px; overflow: hidden;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-modern mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Email / Tên đăng nhập</th>
                            <th>Số điện thoại</th>
                            <th>Trạng thái Email</th>
                            <th class="text-end pe-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2 text-forest"></i>
                                    Chưa có tài khoản nào được tạo.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <img src="/images/avatars/@(item.Id).jpg"
                                                 onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=@item.UserName&background=1a3a28&color=fff&size=80&bold=true';"
                                                 class="rounded-circle shadow-sm me-3"
                                                 style="width: 45px; height: 45px; object-fit: cover; border: 2px solid #eaf5ea;" alt="@item.UserName">

                                            <span class="fw-bold text-dark">@item.UserName</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="text-muted small">
                                            <i class="bi bi-telephone me-1"></i>
                                            @(string.IsNullOrEmpty(item.PhoneNumber) ? "Trống" : item.PhoneNumber)
                                        </span>
                                    </td>
                                    <td>
                                        @if (item.EmailConfirmed)
                                        {
                                            <span class="status-badge status-active">
                                                <i class="bi bi-patch-check-fill me-1"></i> Đã kích hoạt
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-pending">
                                                <i class="bi bi-hourglass-split me-1"></i> Chưa kích hoạt
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                                onclick="confirmDeleteAccount('@item.Email')">
                                            <i class="bi bi-trash3 me-1"></i> Xóa
                                        </button>

                                        <form id="delete-form-@item.Email" asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:none;">
                                            @Html.AntiForgeryToken()
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDeleteAccount(email) {
            Swal.fire({
                title: 'Xóa tài khoản nhân viên?',
                html: `Bạn có chắc chắn muốn xóa tài khoản <b class="text-danger">${email}</b>?<br><small class="text-muted">Hành động này không thể hoàn tác!</small>`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#198754',
                confirmButtonText: 'Đúng, xóa ngay!',
                cancelButtonText: 'Không, giữ lại',
                reverseButtons: true,
                borderRadius: '20px'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('delete-form-' + email).submit();
                }
            })
        }
    </script>
}