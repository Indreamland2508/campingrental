@model BAOCAOWEBNANGCAO.Models.Combo

@{
    ViewData["Title"] = "Thêm Mới Combo";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml"; // Đổi thành Layout Admin thực tế của bạn
}

<div class="container mt-4">
    <h2 class="mb-4 text-success fw-bold">Thêm Mới Gói Combo</h2>

    <form asp-action="Create" enctype="multipart/form-data">
        <div class="row g-4">

            <div class="col-md-7">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-3 border-bottom pb-2">Thông tin gói</h5>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Tên Combo <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="Vd: Combo Tân Binh..." required />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label fw-bold">Giá thuê trọn gói (VNĐ) <span class="text-danger">*</span></label>
                            <input asp-for="Price" type="number" id="ComboPrice" class="form-control fw-bold text-danger" placeholder="0" required />
                            <small class="text-muted fst-italic">Giá này tự động cộng dồn khi bạn chọn đồ bên phải. Bạn có thể sửa lại nếu muốn bán rẻ hơn.</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Badge" class="form-label fw-bold">Nhãn dán (Tùy chọn)</label>
                            <input asp-for="Badge" class="form-control" placeholder="Vd: Best Seller, Cao cấp, Giảm 20%..." />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Ảnh đại diện Combo</label>
                            <input type="file" name="ImageUpload" class="form-control" accept="image/*" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả ngắn</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Gói này dành cho ai..."></textarea>
                        </div>

                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" asp-for="IsActive" checked>
                            <label class="form-check-label" asp-for="IsActive">Hiển thị trên trang chủ</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body p-4 d-flex flex-column">
                        <h5 class="card-title fw-bold mb-3 border-bottom pb-2">
                            Thành phần Combo <span class="text-danger">*</span>
                        </h5>
                        <p class="small text-muted mb-3">Tick chọn sản phẩm và nhập số lượng tương ứng:</p>

                        <div class="flex-grow-1" style="max-height: 550px; overflow-y: auto; border: 1px solid #e1e4e8; border-radius: 8px; padding: 10px; background-color: #f8f9fa;">

                            @if (ViewBag.Products != null)
                            {
                                foreach (var product in (List<BAOCAOWEBNANGCAO.Models.Product>)ViewBag.Products)
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-2 p-2 border rounded bg-white shadow-sm">

                                        <div class="form-check mb-0">
                                            <input class="form-check-input product-checkbox" type="checkbox" name="SelectedProductIds" value="@product.Id" id="prod_@product.Id" data-price="@product.PricePerDay" style="cursor: pointer;">
                                            <label class="form-check-label" for="prod_@product.Id" style="cursor: pointer; line-height: 1.2;">
                                                <strong class="text-dark" style="font-size: 0.9rem;">@product.Name</strong> <br />
                                                <span class="text-success small fw-bold">@product.PricePerDay.ToString("N0") đ</span>
                                            </label>
                                        </div>

                                        <div class="qty-control ms-2" style="display: none;">
                                            <input type="number" name="Quantities_@product.Id" class="form-control form-control-sm product-qty text-center" value="1" min="1" style="width: 65px; font-weight: bold;">
                                        </div>

                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-danger">Chưa có sản phẩm nào trong kho!</p>
                            }

                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-success px-5 py-2 fw-bold shadow-sm"><i class="bi bi-save me-2"></i> LƯU COMBO</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2 py-2">Hủy bỏ</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const checkboxes = document.querySelectorAll('.product-checkbox');
            const priceInput = document.getElementById('ComboPrice');
            const qtyInputs = document.querySelectorAll('.product-qty');

            // Hàm tính tổng tiền
            function calculateTotalPrice() {
                let total = 0;
                checkboxes.forEach(cb => {
                    if (cb.checked) {
                        const price = parseFloat(cb.getAttribute('data-price')) || 0;
                        const productId = cb.value;
                        const qtyInput = document.querySelector(`input[name="Quantities_${productId}"]`);
                        const qty = parseInt(qtyInput.value) || 1;

                        total += (price * qty);
                    }
                });
                // Cập nhật ô input Giá tiền
                priceInput.value = total;
            }

            // Bắt sự kiện khi Tick / Bỏ tick Checkbox
            checkboxes.forEach(cb => {
                cb.addEventListener('change', function () {
                    // Tìm cái ô nhập số lượng bên cạnh nó
                    const qtyControl = this.closest('.d-flex').querySelector('.qty-control');
                    const qtyInput = qtyControl.querySelector('input');

                    if (this.checked) {
                        qtyControl.style.display = 'block'; // Hiện ô số lượng
                    } else {
                        qtyControl.style.display = 'none';  // Ẩn ô số lượng
                        qtyInput.value = 1; // Reset về 1
                    }

                    // Tính lại giá
                    calculateTotalPrice();
                });
            });

            // Bắt sự kiện khi sửa ô số lượng
            qtyInputs.forEach(input => {
                input.addEventListener('input', function() {
                    // Nếu người dùng lỡ nhập số âm hoặc xóa trắng, ép về 1
                    if(this.value < 1 || this.value === '') {
                        this.value = 1;
                    }
                    calculateTotalPrice();
                });
            });
        });
    </script>
}