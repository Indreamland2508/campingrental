@model BAOCAOWEBNANGCAO.Models.Product

@{
    ViewData["Title"] = "Xóa sản phẩm";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-lg-6 col-md-8 mx-auto mt-5">

            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">⚠ Xác nhận xóa sản phẩm</h5>
                </div>

                <div class="card-body">

                    <div class="alert alert-warning">
                        Bạn có chắc chắn muốn xóa sản phẩm này không?  
                        <strong>Hành động này không thể hoàn tác!</strong>
                    </div>

                    <div class="d-flex align-items-center mb-3">
                        <img src="@Model.ImageUrl" class="img-thumbnail me-3" style="width:100px;" />
                        <div>
                            <h6 class="mb-1">@Model.Name</h6>
                            <small class="text-muted">@Model.Category?.Name</small>
                        </div>
                    </div>

                    <ul class="list-group mb-3">
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Giá / ngày</span>
                            <strong>@Model.PricePerDay.ToString("N0") đ</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Số lượng</span>
                            <strong>@Model.Quantity</strong>
                        </li>
                    </ul>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">← Hủy</a>
                            <button type="submit" class="btn btn-danger">🗑 Xóa sản phẩm</button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>
