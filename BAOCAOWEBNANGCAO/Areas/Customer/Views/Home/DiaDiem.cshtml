@{
    ViewData["Title"] = "Tọa độ dã ngoại";
}

<link rel="stylesheet" href="~/css/Home.DiaDiem.css" />

<div class="location-header fade-up">
    <div class="container">
        <h1 class="location-main-title font-serif">Tọa Độ Khám Phá</h1>
        <p class="text-muted fs-5">Những địa điểm cắm trại tuyệt đẹp xung quanh Hà Nội do Camping Rental chọn lọc.</p>
    </div>
</div>

<div class="container pb-5">

    <div class="row mb-5 pb-4 fade-up" style="transition-delay: 0.2s;">
        <div class="col-lg-7 mb-4 mb-lg-0">
            <div class="map-container">
                <iframe width="100%" height="100%" frameborder="0" scrolling="no" marginheight="0" marginwidth="0"
                        src="https://maps.google.com/maps?q=Hồ%20Đồng%20Đỏ,%20Sóc%20Sơn,%20Hà%20Nội&t=&z=14&ie=UTF8&iwloc=&output=embed"
                        style="border:0;" allowfullscreen>
                </iframe>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="location-info-card">
                <div><span class="loc-badge">Điểm đến nổi bật tuần này</span></div>
                <h2 class="loc-title font-serif">Hồ Đồng Đỏ, Sóc Sơn</h2>

                <div class="loc-detail-item mt-3">
                    <i class="bi bi-geo-alt-fill loc-detail-icon"></i>
                    <div>
                        <strong class="d-block text-dark">Vị trí</strong>
                        <span class="text-muted">Minh Trí, Sóc Sơn, Hà Nội (Cách trung tâm HN ~40km)</span>
                    </div>
                </div>

                <div class="loc-detail-item">
                    <i class="bi bi-compass loc-detail-icon"></i>
                    <div>
                        <strong class="d-block text-dark">Địa hình & Cảnh quan</strong>
                        <span class="text-muted">Hồ nước ngọt rộng lớn bao quanh bởi rừng thông nguyên sinh. Phù hợp chèo SUP và nướng BBQ ven hồ.</span>
                    </div>
                </div>

                <div class="loc-detail-item">
                    <i class="bi bi-backpack loc-detail-icon"></i>
                    <div>
                        <strong class="d-block text-dark">Trang bị đề xuất từ Camping Rental</strong>
                        <span class="text-muted">Lều 4-6 người chống nước, Bếp nướng BBQ inox, Bàn ghế xếp gọn, Đèn bão retro.</span>
                    </div>
                </div>

                <a href="/Home/ProductList" class="btn btn-dark rounded-pill py-3 px-4 mt-4 text-uppercase fw-bold" style="letter-spacing: 1px; font-size: 0.9rem;">
                    Chuẩn bị đồ ngay <i class="bi bi-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="row mt-5 pt-4">
        <div class="col-12 mb-4 fade-up">
            <h3 class="font-serif fw-bold text-dark">Các tọa độ cực "chill" khác</h3>
        </div>

        <div class="col-lg-4 col-md-6 mb-4 fade-up" style="transition-delay: 0.1s;">
            <a href="#" class="other-loc-card shadow-sm">
                <img src="/images/diadiem/anh1.webp" class="other-loc-img" alt="Đồng Mô">
                <div class="other-loc-overlay">
                    <h3 class="other-loc-title">Sơn Tinh Camp, Đồng Mô</h3>
                    <span class="text-light small"><i class="bi bi-car-front"></i> 45 phút lái xe</span>
                </div>
            </a>
        </div>

        <div class="col-lg-4 col-md-6 mb-4 fade-up" style="transition-delay: 0.2s;">
            <a href="#" class="other-loc-card shadow-sm">
                <img src="/images/diadiem/anh2.jpg" class="other-loc-img" alt="Hàm Lợn">
                <div class="other-loc-overlay">
                    <h3 class="other-loc-title">Núi Hàm Lợn, Sóc Sơn</h3>
                    <span class="text-light small"><i class="bi bi-car-front"></i> 1 giờ lái xe</span>
                </div>
            </a>
        </div>

        <div class="col-lg-4 col-md-6 mb-4 fade-up" style="transition-delay: 0.3s;">
            <a href="#" class="other-loc-card shadow-sm">
                <img src="/images/diadiem/anh3.jpg" class="other-loc-img" alt="Ba Vì">
                <div class="other-loc-overlay">
                    <h3 class="other-loc-title">Vườn Quốc Gia Ba Vì</h3>
                    <span class="text-light small"><i class="bi bi-car-front"></i> 1.5 giờ lái xe</span>
                </div>
            </a>
        </div>

    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.15 });

            document.querySelectorAll('.fade-up').forEach((el) => {
                observer.observe(el);
            });
        });
    </script>
}