@model BAOCAOWEBNANGCAO.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<link rel="stylesheet" href="~/css/Home.Details.css" />

<div class="container luxury-container">
    <nav style="--bs-breadcrumb-divider: '·';" class="mb-5">
        <ol class="breadcrumb small text-uppercase fw-bold" style="letter-spacing: 1.5px; font-size: 0.75rem;">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="ProductList" class="text-decoration-none text-muted">Shop</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="ProductList" asp-route-category="@Model.Category?.Name" class="text-decoration-none text-muted">
                    @Model.Category?.Name
                </a>
            </li>
            <li class="breadcrumb-item active" style="color: var(--forest-dark);">Chi tiết</li>
        </ol>
    </nav>

    <div class="row g-5">
        <div class="col-lg-6">
            <div class="img-display-frame">
                <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/no-image.png" : Model.ImageUrl)" alt="@Model.Name">
            </div>
        </div>

        <div class="col-lg-5 offset-lg-1">
            <div class="product-details-sticky">
                <span class="product-meta">Mã sản phẩm: #@Model.Id</span>
                <h1 class="product-name-luxury">@Model.Name</h1>
                <div class="price-tag-luxury">@Model.PricePerDay.ToString("#,##0")₫ <span class="text-muted fs-6 fw-normal font-sans-serif">/ ngày</span></div>

                <div class="luxury-description">
                    @Model.Description
                </div>

                <form asp-controller="Cart" asp-action="AddToCart" method="post">
                    <input type="hidden" name="productId" value="@Model.Id" />

                    <div class="quantity-row">
                        <span class="quantity-label">Số lượng</span>
                        <div class="quantity-control">
                            <input type="number" name="quantity" value="1" min="1" max="@Model.Quantity" class="quantity-input">
                        </div>
                        <span class="text-muted small">(@Model.Quantity sản phẩm sẵn có)</span>
                    </div>

                    <div class="mb-5">
                        @if (Model.Quantity > 0)
                        {
                            <button type="submit" class="btn-luxury-action shadow-sm">
                                Thêm Vào Túi Đồ Của Bạn
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-secondary w-100 rounded-pill py-3" disabled style="background-color: #f3f4f6; color: #9ca3af; border: none; font-weight: 700; letter-spacing: 1px;">
                                TẠM HẾT HÀNG
                            </button>
                        }
                    </div>
                </form>

                <div class="mt-5">
                    <a href="#" class="info-collapse-item">
                        <span>Đặc tính sản phẩm</span>
                        <i class="bi bi-plus"></i>
                    </a>
                    <a href="#" class="info-collapse-item">
                        <span>Chính sách thuê & Trả đồ</span>
                        <i class="bi bi-plus"></i>
                    </a>
                    <a href="#" class="info-collapse-item">
                        <span>Dịch vụ hỗ trợ tại trại</span>
                        <i class="bi bi-plus"></i>
                    </a>
                </div>

                <div class="quality-icons">
                    <div class="text-center">
                        <i class="bi bi-shield-check"></i>
                        <p>Đảm bảo chất lượng</p>
                    </div>
                    <div class="text-center">
                        <i class="bi bi-stars"></i>
                        <p>Vệ sinh tiêu chuẩn</p>
                    </div>
                    <div class="text-center">
                        <i class="bi bi-truck"></i>
                        <p>Giao tận nơi</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>