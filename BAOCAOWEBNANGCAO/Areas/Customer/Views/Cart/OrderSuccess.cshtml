@model BAOCAOWEBNANGCAO.Models.Order

@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<link rel="stylesheet" href="~/css/Cart.OrderSuccess.css" />

<div class="container mt-5 text-center mb-5 pb-5">

    <div class="mb-4 pt-3">
        <i class="bi bi-check-circle-fill text-success" style="font-size: 4.5rem; text-shadow: 0 5px 15px rgba(25, 135, 84, 0.2);"></i>
    </div>

    <h1 class="text-forest font-serif fw-bold mb-3">Giao dịch thành công.</h1>
    <h5 class="text-muted fw-normal mb-5">Cảm ơn bạn đã lựa chọn dịch vụ của chúng tôi! Đơn hàng đã được xác nhận.</h5>

    <div class="receipt-card mx-auto mt-2 mb-5" style="max-width: 480px;">
        <div class="card-body p-4 p-md-5 text-start">

            <div class="d-flex justify-content-between align-items-center border-bottom border-light pb-3 mb-3">
                <span class="text-muted text-uppercase small fw-bold" style="letter-spacing: 1px;">Mã Đơn Đặt Trước</span>
                <strong class="text-forest fs-5">#@Model.Id</strong>
            </div>

            <div class="d-flex justify-content-between align-items-center border-bottom border-light pb-3 mb-3">
                <span class="text-muted text-uppercase small fw-bold" style="letter-spacing: 1px;">Trạng thái cọc</span>
                <span class="badge bg-success rounded-pill px-3 py-2"><i class="bi bi-shield-check me-1"></i> Đã nhận tiền</span>
            </div>

            <div class="d-flex justify-content-between align-items-center pt-2 bg-light p-3 rounded-3 mt-4">
                <span class="text-muted text-uppercase small fw-bold" style="letter-spacing: 0.5px;">Cần thu lúc nhận đồ:</span>
                <strong class="text-danger fs-4 mb-0">@Model.RemainingAmount.ToString("N0") ₫</strong>
            </div>

        </div>
    </div>

    <div class="mt-4">
        <p class="text-muted fs-6 mb-4" style="max-width: 600px; margin: 0 auto; line-height: 1.6;">
            Chúng tôi đang chuẩn bị các thiết bị cắm trại tốt nhất cho bạn. Sẽ có nhân viên liên hệ qua số điện thoại
            <strong class="text-dark">@Model.CustomerPhone</strong> trong thời gian sớm nhất để chốt lịch giao nhận.
        </p>
        <a href="/" class="btn-elegant mt-2 d-inline-block text-decoration-none">
            <i class="bi bi-arrow-left me-2"></i> Trở về trang chủ
        </a>
    </div>

</div>