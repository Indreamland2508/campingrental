@model List<BAOCAOWEBNANGCAO.Models.CartItem>
@{
    ViewData["Title"] = "Thanh toán";
    decimal cartTotal = Model.Sum(item => item.TotalPrice);
}

<link rel="stylesheet" href="~/css/Cart.Checkout.css" />

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-5">
        <h1 class="checkout-main-title font-serif m-0">Thanh toán</h1>
        <a asp-controller="Cart" asp-action="Index" class="text-decoration-none text-muted fw-bold">
            <i class="bi bi-arrow-left me-1"></i> Sửa giỏ hàng
        </a>
    </div>

    <form asp-action="Checkout" method="post" id="checkoutForm">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        <div class="row g-5">

            <div class="col-lg-7">
                <div class="checkout-card p-4 p-md-5 mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h4 class="card-title-section m-0">Thông tin nhận hàng</h4>
                        <a asp-area="Identity" asp-page="/Account/Login" class="text-decoration-none" style="color: var(--forest-dark); font-weight: bold; font-size: 0.9rem;">
                            <i class="bi bi-person-circle"></i> Đăng nhập
                        </a>
                    </div>

                    <div class="row g-4">
                        <div class="col-12">
                            <label>Họ và tên người thuê <span class="text-danger">*</span></label>
                            <input type="text" name="CustomerName" value="@(ViewBag.CustomerName ?? string.Empty)" class="form-control" required placeholder="Nhập họ và tên đầy đủ">
                        </div>
                        <div class="col-md-6">
                            <label>Số điện thoại <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-muted border-end-0" style="border-radius: 10px 0 0 10px; border-color: var(--border-color);">+84</span>
                                <input type="tel" name="CustomerPhone" value="@(ViewBag.CustomerPhone ?? string.Empty)" class="form-control border-start-0" style="border-radius: 0 10px 10px 0;" required pattern="[0-9]{9,10}" title="Nhập 9-10 chữ số" placeholder="982...">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label>Email liên hệ <span class="text-danger">*</span></label>
                            <input type="email" name="CustomerEmail" value="@(ViewBag.CustomerEmail ?? string.Empty)" class="form-control" required placeholder="Để nhận thông báo đơn hàng">
                        </div>
                        <div class="col-12">
                            <label>Địa chỉ nhận lều <span class="text-danger">*</span></label>
                            <input type="text" name="ShippingAddress" value="@(ViewBag.ShippingAddress ?? string.Empty)" class="form-control" required placeholder="Số nhà, Tên đường, Phường/Xã...">
                        </div>
                        <div class="col-12">
                            <label>Ghi chú cho chuyến đi</label>
                            <textarea name="Note" class="form-control" rows="3" placeholder="Ví dụ: Giao lều trước 8h sáng, cần tư vấn thêm cách dựng lều...">@(ViewBag.Note ?? string.Empty)</textarea>
                        </div>
                    </div>
                </div>

                <div class="checkout-card p-4 p-md-5">
                    <h4 class="card-title-section mb-4"><i class="bi bi-calendar-event me-2" style="color: var(--forest-dark);"></i>Lịch trình thuê</h4>
                    <div class="rental-time-box p-4">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-5">
                                <label>Ngày nhận đồ <span class="text-danger">*</span></label>
                                <input type="date" name="rentalStart" id="rentalStart" class="form-control bg-white" required value="@(ViewBag.RentalStart ?? DateTime.Now.ToString("yyyy-MM-dd"))">
                            </div>
                            <div class="col-md-5">
                                <label>Ngày trả đồ <span class="text-danger">*</span></label>
                                <input type="date" name="rentalEnd" id="rentalEnd" class="form-control bg-white" required value="@(ViewBag.RentalEnd ?? DateTime.Now.AddDays(1).ToString("yyyy-MM-dd"))">
                            </div>
                            <div class="col-md-2 text-md-end text-center mt-3 mt-md-0">
                                <span class="d-inline-block bg-white border px-3 py-2 rounded-3 fw-bold text-dark shadow-sm" id="dayCountText" style="font-size: 0.9rem;">1 ngày</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="checkout-card order-summary-box p-4 p-md-5">
                    <h4 class="card-title-section border-bottom pb-3 mb-4">Đơn hàng (@Model.Count món)</h4>

                    <div class="mb-4" style="max-height: 320px; overflow-y: auto; padding-right: 5px;">
                        @foreach (var item in Model)
                        {
                            <div class="d-flex align-items-center justify-content-between mb-3 pb-3 border-bottom border-light">
                                <div class="d-flex align-items-center">
                                    <div class="position-relative me-3">
                                        <img src="@(string.IsNullOrEmpty(item.Product.ImageUrl) ? "/images/no-image.png" : item.Product.ImageUrl)" class="summary-img">
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill badge-qty shadow-sm">@item.Quantity</span>
                                    </div>
                                    <div>
                                        <p class="mb-1 fw-bold text-dark" style="font-size: 0.95rem; line-height: 1.2;">@item.Product.Name</p>
                                        <span class="text-muted" style="font-size: 0.8rem;">@item.Product.Category?.Name</span>
                                    </div>
                                </div>
                                <span class="fw-bold text-dark ps-2">@item.TotalPrice.ToString("#,##0")₫</span>
                            </div>
                        }
                    </div>

                    <div class="py-3 mb-2 border-top">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Tạm tính (1 ngày)</span>
                            <span class="fw-semibold">@cartTotal.ToString("#,##0")₫</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 pb-3 border-bottom border-light">
                            <span class="text-muted">Tổng số ngày thuê</span>
                            <span class="fw-bold" style="color: var(--forest-dark);" id="dayCountReview">1</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span class="fw-bold text-uppercase" style="font-size: 0.9rem;">Tổng cộng</span>
                            <span class="fw-bold" style="font-size: 1.6rem; color: var(--text-dark);" id="finalTotal">@cartTotal.ToString("#,##0")₫</span>
                        </div>
                    </div>

                    <div class="deposit-box mt-2 mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="fw-bold text-dark"><i class="bi bi-shield-check me-2" style="color: var(--forest-dark);"></i>Cọc giữ đồ (50%)</span>
                            <span class="fw-bold fs-4" style="color: var(--forest-dark);" id="depositAmount">@((cartTotal / 2).ToString("#,##0"))₫</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center small text-muted border-top pt-2 mt-2">
                            <span>Thanh toán nốt khi nhận</span>
                            <span class="fw-semibold" id="remainingAmount">@((cartTotal / 2).ToString("#,##0"))₫</span>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-checkout-final w-100 text-uppercase d-flex justify-content-between align-items-center shadow-sm">
                        <span>Xác nhận & Thanh toán</span>
                        <i class="bi bi-arrow-right"></i>
                    </button>

                    <p class="text-center text-muted mt-3 mb-0" style="font-size: 0.8rem;">
                        Bằng việc xác nhận, bạn đồng ý với Điều khoản dịch vụ của chúng tôi.
                    </p>
                </div>
            </div>

        </div>
    </form>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const startInput = document.getElementById("rentalStart");
        const endInput = document.getElementById("rentalEnd");
        const dayCountText = document.getElementById("dayCountText");
        const dayCountReview = document.getElementById("dayCountReview");

        const finalTotalSpan = document.getElementById("finalTotal");
        const depositAmountSpan = document.getElementById("depositAmount");
        const remainingAmountSpan = document.getElementById("remainingAmount");

        const basePrice = @cartTotal;

        function updatePrice() {
            const start = new Date(startInput.value);
            const end = new Date(endInput.value);
            const diffTime = end - start;
            let diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

            if (diffDays <= 0) diffDays = 1;

            dayCountText.innerText = diffDays + " ngày";
            dayCountReview.innerText = diffDays;

            const total = basePrice * diffDays;
            const deposit = total / 2;
            const remaining = total - deposit;

            finalTotalSpan.innerText = total.toLocaleString('vi-VN') + "₫";
            depositAmountSpan.innerText = deposit.toLocaleString('vi-VN') + "₫";
            remainingAmountSpan.innerText = remaining.toLocaleString('vi-VN') + "₫";
        }

        startInput.addEventListener("change", updatePrice);
        endInput.addEventListener("change", updatePrice);
    });
</script>

@section Scripts {
    <script>
        // Chống bấm đúp thần chưởng
        $('form').submit(function (e) {
            var btn = $(this).find('button[type="submit"]');
            if (btn.hasClass('disabled')) {
                e.preventDefault();
                return false;
            }
            btn.addClass('disabled').html('<span class="spinner-border spinner-border-sm me-2"></span> Đang xử lý...');
        });
    </script>
}