@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu mới";
}

<style>
    body {
        background: url('/images/IMG/camtrai.jpg') no-repeat center center fixed;
        background-size: cover;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .bg-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.65);
        z-index: -1;
    }

    .reset-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        border: none;
        box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        padding: 40px;
        max-width: 450px;
        width: 100%;
        margin: 80px auto;
    }

    .card-title {
        font-family: 'Playfair Display', serif;
        font-weight: 800;
        color: #1a4d3a;
        font-size: 2rem;
        margin-bottom: 5px;
        text-align: center;
    }

    .form-control {
        border-radius: 12px;
        padding: 14px 20px;
        background-color: #f8f9fa;
        border: 1px solid #e1e4e8;
    }

        .form-control:focus {
            border-color: #1a4d3a;
            box-shadow: 0 0 0 4px rgba(26, 77, 58, 0.1);
        }

    .btn-submit {
        background: linear-gradient(135deg, #198754 0%, #115c30 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 15px;
        font-weight: 700;
        letter-spacing: 1px;
        transition: all 0.3s;
        margin-top: 10px;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(25, 135, 84, 0.3);
            color: white;
        }
</style>

<div class="bg-overlay"></div>

<div class="container">
    <div class="reset-card">
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-3" style="width: 60px; height: 60px; color: #1a4d3a; font-size: 1.5rem;">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h2 class="card-title">Khôi phục bảo mật</h2>
            <p class="text-muted small">Vui lòng thiết lập mật khẩu mới cho tài khoản của bạn.</p>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <input asp-for="Input.Code" type="hidden" />

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label fw-bold small text-muted text-uppercase">Email xác nhận</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Tài khoản email..." />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label fw-bold small text-muted text-uppercase">Mật khẩu mới</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Input.ConfirmPassword" class="form-label fw-bold small text-muted text-uppercase">Nhập lại mật khẩu</label>
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-submit w-100 text-uppercase">Cập nhật mật khẩu</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}