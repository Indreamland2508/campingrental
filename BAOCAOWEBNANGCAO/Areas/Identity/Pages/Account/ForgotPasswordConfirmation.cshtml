@page
@{
    ViewData["Title"] = "Đã gửi yêu cầu";
}

<style>
    body {
        background: url('/images/IMG/camtrai.jpg') no-repeat center center fixed;
        background-size: cover;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .bg-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.65);
        z-index: -1;
    }

    .confirm-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        border: none;
        box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        padding: 40px;
        max-width: 500px;
        width: 100%;
        margin: 80px auto;
        text-align: center;
    }

    .icon-box-success {
        width: 80px;
        height: 80px;
        background-color: rgba(25, 135, 84, 0.1);
        color: #198754;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin-bottom: 20px;
    }

    .card-title {
        font-family: 'Playfair Display', serif;
        font-weight: 800;
        color: #1a4d3a;
        font-size: 1.8rem;
        margin-bottom: 15px;
    }

    .btn-return {
        background: linear-gradient(135deg, #1a4d3a 0%, #113326 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px 30px;
        font-weight: 700;
        transition: all 0.3s;
        text-decoration: none;
        display: inline-block;
        margin-top: 15px;
    }

        .btn-return:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(26, 77, 58, 0.3);
            color: white;
        }
</style>

<div class="bg-overlay"></div>

<div class="container">
    <div class="confirm-card">
        <div class="icon-box-success">
            <i class="bi bi-envelope-check-fill"></i>
        </div>
        <h2 class="card-title">Kiểm tra hộp thư của bạn</h2>
        <p class="text-muted mb-4 px-3" style="line-height: 1.6;">
            Hệ thống đã gửi một đường dẫn đặt lại mật khẩu đến email của bạn. Vui lòng kiểm tra cả hộp thư đến và thư rác (Spam).
        </p>

        <a asp-page="./Login" class="btn-return text-uppercase">
            <i class="bi bi-arrow-left me-2"></i>Quay lại Đăng nhập
        </a>
    </div>
</div>