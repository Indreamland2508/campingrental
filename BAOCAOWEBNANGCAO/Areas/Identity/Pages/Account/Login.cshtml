@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập nội bộ";
    // Ẩn Header và Footer của khách hàng nếu bạn muốn trang Login đứng độc lập,
    // Nếu muốn giữ Header thì xóa dòng Layout = null; đi nhé.
    // Layout = null;
}

<link rel="stylesheet" href="~/css/Identity.Login.css" />

<div class="bg-overlay"></div>

<div class="container">
    <div class="login-card">
        <div class="text-center mb-4">
            <h1 class="brand-title m-0">CAMPING</h1>
            <h1 class="brand-title m-0" style="color: #111;">RENTAL</h1>
            <p class="text-muted mt-2 fw-bold" style="letter-spacing: 2px; font-size: 0.8rem;">HỆ THỐNG QUẢN TRỊ</p>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label fw-bold small text-muted text-uppercase">Tài khoản Email</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="admin@campingrental.vn" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <label asp-for="Input.Password" class="form-label fw-bold small text-muted text-uppercase m-0">Mật khẩu</label>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="small text-decoration-none" style="color: #1a4d3a; font-weight: 600;">Quên mật khẩu?</a>
                </div>

                <div class="position-relative mt-2">
                    <input asp-for="Input.Password" id="passwordInput" class="form-control" autocomplete="current-password" aria-required="true" placeholder="••••••••" style="padding-right: 45px;" />
                    <button type="button" id="togglePasswordBtn" class="btn-toggle-password" title="Hiển thị mật khẩu">
                        <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-eye-fill" viewBox="0 0 16 16">
                            <path d="M10.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0z" />
                            <path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8zm8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7z" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div class="mb-4 form-check">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <label class="form-check-label fw-bold text-muted small" asp-for="Input.RememberMe">
                    Duy trì đăng nhập
                </label>
            </div>

            <div>
                <button id="login-submit" type="submit" class="btn btn-login w-100 text-uppercase">Đăng nhập hệ thống</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const togglePasswordBtn = document.getElementById('togglePasswordBtn');
            const passwordInput = document.getElementById('passwordInput');
            const eyeIcon = document.getElementById('eyeIcon');

            // SVG icon cho mắt mở và nhắm
            const eyeOpenSvg = '<path d="M10.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0z"/><path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8zm8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7z"/>';
            const eyeSlashSvg = '<path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7.028 7.028 0 0 0-2.79.588l.77.771A5.944 5.944 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.134 13.134 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755l-.809-.805zm-4.706-4.706L7.126 5.006A2.5 2.5 0 0 1 10.5 8.374l-1.847-1.842zm-2.091 2.092L4.208 6.273A2.5 2.5 0 0 0 7.727 9.792l1.636 1.636a2.5 2.5 0 0 1-2.801-2.804zm8.653 7.828-1-1-10-10-1-1 1.414-1.414 10 10 1.414 1.414-1.414 1.414z"/><path d="M2.316 4.318A13.11 13.11 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l-1.146-1.146A4.954 4.954 0 0 1 8 11.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>';

            togglePasswordBtn.addEventListener('click', function () {
                // Kiểm tra loại input hiện tại
                const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                passwordInput.setAttribute('type', type);

                // Đổi icon và title tương ứng
                if (type === 'text') {
                    eyeIcon.innerHTML = eyeSlashSvg;
                    togglePasswordBtn.setAttribute('title', 'Ẩn mật khẩu');
                } else {
                    eyeIcon.innerHTML = eyeOpenSvg;
                    togglePasswordBtn.setAttribute('title', 'Hiển thị mật khẩu');
                }
            });
        });
    </script>
}