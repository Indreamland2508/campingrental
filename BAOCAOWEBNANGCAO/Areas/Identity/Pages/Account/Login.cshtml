@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập nội bộ";
    // Ẩn Header và Footer của khách hàng nếu bạn muốn trang Login đứng độc lập,
    // Nếu muốn giữ Header thì xóa dòng Layout = null; đi nhé.
    // Layout = null;
}

<style>
    body {
        background: url('/images/IMG/camtrai.jpg') no-repeat center center fixed;
        background-size: cover;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    /* Lớp phủ đen mờ để làm nổi bật form */
    .bg-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.6);
        z-index: -1;
    }

    .login-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        border: none;
        box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        padding: 40px;
        max-width: 450px;
        width: 100%;
        margin: 80px auto;
    }

    .brand-title {
        font-family: 'Playfair Display', serif;
        font-weight: 800;
        color: #1a4d3a;
        font-size: 2.5rem;
    }

    .form-control {
        border-radius: 12px;
        padding: 14px 20px;
        background-color: #f8f9fa;
        border: 1px solid #e1e4e8;
    }

        .form-control:focus {
            border-color: #1a4d3a;
            box-shadow: 0 0 0 4px rgba(26, 77, 58, 0.1);
        }

    .btn-login {
        background: linear-gradient(135deg, #198754 0%, #115c30 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 15px;
        font-weight: 700;
        letter-spacing: 1px;
        transition: all 0.3s;
    }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(26, 77, 58, 0.3);
            color: white;
        }
</style>

<div class="bg-overlay"></div>

<div class="container">
    <div class="login-card">
        <div class="text-center mb-4">
            <h1 class="brand-title m-0">CAMPING</h1>
            <h1 class="brand-title m-0" style="color: #111;">RENTAL</h1>
            <p class="text-muted mt-2 fw-bold" style="letter-spacing: 2px; font-size: 0.8rem;">HỆ THỐNG QUẢN TRỊ</p>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label fw-bold small text-muted text-uppercase">Tài khoản Email</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="admin@campingrental.vn" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <label asp-for="Input.Password" class="form-label fw-bold small text-muted text-uppercase m-0">Mật khẩu</label>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="small text-decoration-none" style="color: #1a4d3a; font-weight: 600;">Quên mật khẩu?</a>
                </div>
                <input asp-for="Input.Password" class="form-control mt-2" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div class="mb-4 form-check">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <label class="form-check-label fw-bold text-muted small" asp-for="Input.RememberMe">
                    Duy trì đăng nhập
                </label>
            </div>

            <div>
                <button id="login-submit" type="submit" class="btn btn-login w-100 text-uppercase">Đăng nhập hệ thống</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}