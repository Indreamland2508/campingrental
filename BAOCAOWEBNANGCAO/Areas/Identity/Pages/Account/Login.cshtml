@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<style>
    /* 1. NỀN TRANG TRẮNG XÁM NHẸ NHƯ TRANG CHỦ */
    body {
        background-color: #f4f7f6; /* Màu nền xám xanh cực nhẹ */
        background-image: none; /* Bỏ ảnh nền tràn màn hình để tập trung vào form */
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .auth-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    /* 2. CARD ĐĂNG NHẬP TRẮNG SÁNG, BO GÓC 30PX GIỐNG TRANG CHỦ */
    .auth-card {
        background: #ffffff;
        border-radius: 30px; /* Bo góc cực sâu đồng bộ với trang chủ */
        box-shadow: 0 20px 60px rgba(0,0,0,0.05); /* Bóng đổ đổ nhẹ nhàng */
        width: 100%;
        max-width: 900px; /* Thiết kế dạng ngang cho sang trọng */
        display: flex;
        overflow: hidden;
        border: 1px solid rgba(0,0,0,0.02);
    }

    /* Phía bên trái: Ảnh decor lều trại */
    .auth-side-image {
        width: 50%;
        background-image: url('https://images.unsplash.com/photo-1523987355523-c7b5b0dd90a7?q=80&w=2070&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        display: none; /* Hiện ở màn hình lớn */
    }

    /* Phía bên phải: Form đăng nhập */
    .auth-form-side {
        width: 100%;
        padding: 50px;
    }

    @@media (min-width: 768px) {
        .auth-side-image {
            display: block;
        }

        .auth-form-side {
            width: 50%;
        }
    }

    /* 3. INPUT FIELD PHONG CÁCH HIỆN ĐẠI */
    .form-floating > .form-control {
        border-radius: 15px;
        border: 1px solid #e0e0e0;
        background-color: #f9f9f9;
        padding-left: 20px;
    }

        .form-floating > .form-control:focus {
            border-color: #198754; /* Màu xanh lá trang chủ */
            background-color: #fff;
            box-shadow: 0 0 0 4px rgba(25, 135, 84, 0.1);
        }

    /* 4. NÚT BẤM XANH LÁ ĐẶC TRƯNG */
    .btn-camping-primary {
        background-color: #198754; /* Xanh lá trang chủ */
        color: white;
        border: none;
        border-radius: 15px;
        padding: 15px;
        font-weight: 700;
        transition: all 0.3s ease;
    }

        .btn-camping-primary:hover {
            background-color: #157347;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(25, 135, 84, 0.2);
        }

    .auth-link {
        color: #198754;
        text-decoration: none;
        font-weight: 600;
    }

        .auth-link:hover {
            color: #157347;
            text-decoration: underline;
        }
</style>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-side-image"></div>

        <div class="auth-form-side">
            <div class="text-center mb-5">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                    <h3 class="fw-bold text-success mb-2"><i class="bi bi-tent"></i> CAMPING RENTAL</h3>
                </a>
                <p class="text-muted small">Vui lòng đăng nhập để tiếp tục</p>
            </div>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Địa chỉ Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" type="password" />
                    <label asp-for="Input.Password">Mật khẩu</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label text-muted small" asp-for="Input.RememberMe">Ghi nhớ tôi</label>
                    </div>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="auth-link small">Quên mật khẩu?</a>
                </div>

                <button id="login-submit" type="submit" class="btn btn-camping-primary w-100 mb-4">ĐĂNG NHẬP NGAY</button>

                <div class="text-center">
                    <p class="text-muted small">
                        Chưa có tài khoản? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="auth-link">Đăng ký mới</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}