@page
@{
    ViewData["Title"] = "Đổi mật khẩu thành công";
}

<link rel="stylesheet" href="~/css/Identity.ResetPasswordConfirmation.css" />

<div class="bg-overlay"></div>

<div class="container">
    <div class="confirm-card">
        <div class="icon-box-success">
            <i class="bi bi-check-circle-fill"></i>
        </div>
        <h2 class="card-title">Thành công!</h2>
        <p class="text-muted mb-4 px-3" style="line-height: 1.6;">
            Tài khoản của bạn đã được cập nhật mật khẩu mới an toàn. Vui lòng đăng nhập lại để tiếp tục sử dụng hệ thống.
        </p>

        <a asp-page="./Login" class="btn-login text-uppercase">
            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập ngay
        </a>
    </div>
</div>