@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<link rel="stylesheet" href="~/css/Identity.ForgotPassword.css" />

<div class="bg-overlay"></div>

<div class="container">
    <div class="forgot-card">
        <div class="icon-box">
            <i class="bi bi-key"></i>
        </div>
        <h2 class="card-title">Khôi phục mật khẩu</h2>
        <p class="text-muted small mb-4 px-3" style="line-height: 1.6;">
            Nhập địa chỉ email liên kết với tài khoản của bạn. Hệ thống sẽ gửi một đường dẫn để đặt lại mật khẩu an toàn.
        </p>

        <form method="post" class="text-start">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-center"></div>

            <div class="mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Nhập email của bạn..." />
                <span asp-validation-for="Input.Email" class="text-danger small d-block text-center mt-1"></span>
            </div>

            <button type="submit" class="btn btn-reset w-100">GỬI YÊU CẦU</button>
        </form>

        <a asp-page="./Login" class="back-link">
            <i class="bi bi-arrow-left me-1"></i> Quay lại trang Đăng nhập
        </a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}