@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<style>
    body {
        background: url('/images/IMG/camtrai.jpg') no-repeat center center fixed;
        background-size: cover;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .bg-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.65);
        z-index: -1;
    }

    .forgot-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        border: none;
        box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        padding: 40px;
        max-width: 450px;
        width: 100%;
        margin: 80px auto;
        text-align: center;
    }

    .icon-box {
        width: 70px;
        height: 70px;
        background-color: rgba(26, 77, 58, 0.1);
        color: #1a4d3a;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin-bottom: 20px;
    }

    .card-title {
        font-family: 'Playfair Display', serif;
        font-weight: 800;
        color: #111;
        font-size: 1.8rem;
        margin-bottom: 10px;
    }

    .form-control {
        border-radius: 12px;
        padding: 14px 20px;
        background-color: #f8f9fa;
        border: 1px solid #e1e4e8;
        text-align: center;
    }

        .form-control:focus {
            border-color: #1a4d3a;
            box-shadow: 0 0 0 4px rgba(26, 77, 58, 0.1);
        }

    .btn-reset {
        background: linear-gradient(135deg, #198754 0%, #115c30 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 15px;
        font-weight: 700;
        letter-spacing: 0.5px;
        transition: all 0.3s;
        margin-top: 20px;
    }

        .btn-reset:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(26, 77, 58, 0.3);
            color: white;
        }

    .back-link {
        color: #6c757d;
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        display: inline-block;
        margin-top: 20px;
        transition: 0.2s;
    }

        .back-link:hover {
            color: #1a4d3a;
        }
</style>

<div class="bg-overlay"></div>

<div class="container">
    <div class="forgot-card">
        <div class="icon-box">
            <i class="bi bi-key"></i>
        </div>
        <h2 class="card-title">Khôi phục mật khẩu</h2>
        <p class="text-muted small mb-4 px-3" style="line-height: 1.6;">
            Nhập địa chỉ email liên kết với tài khoản của bạn. Hệ thống sẽ gửi một đường dẫn để đặt lại mật khẩu an toàn.
        </p>

        <form method="post" class="text-start">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-center"></div>

            <div class="mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Nhập email của bạn..." />
                <span asp-validation-for="Input.Email" class="text-danger small d-block text-center mt-1"></span>
            </div>

            <button type="submit" class="btn btn-reset w-100">GỬI YÊU CẦU</button>
        </form>

        <a asp-page="./Login" class="back-link">
            <i class="bi bi-arrow-left me-1"></i> Quay lại trang Đăng nhập
        </a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}